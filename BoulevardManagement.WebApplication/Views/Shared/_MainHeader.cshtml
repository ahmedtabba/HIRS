<script>
    var isRTL = '@System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft';
    if (isRTL == 'True')
    {
        $("#ar-lang").addClass("active-lang");
        $("#en-lang").removeClass("active-lang");
    }
    else {
        $("#en-lang").addClass("active-lang");
        $("#ar-lang").removeClass("active-lang");
    }

</script>