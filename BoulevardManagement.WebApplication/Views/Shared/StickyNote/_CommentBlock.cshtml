                <!--End ReplyBlock-->
            }


        </div>
    </div>
</div>

@*********************************************************************************************************@





<script>

    var ObjectType = "";
    var ObjectId = "";
    var ObjectTag = "";
    var datachannelreply = 0;
    var IsRecordReplyPressed = false;

    $(document).ready(function () {
        debugger;
        $('.recordReplyButtonClass').addClass("notRec");

    });


    function removeBookMark(commentId,objectType) {
         var data = {
             commentId: commentId
            };



            $.ajax({
                type: 'POST',
                url: "@Url.Action("RemoveBookMarkNote", "StickyNote", new { @Area = "" })",
                data: data,
                dataType: 'json',
                success: function (data) {
                    $(`#bookMarkContainer-${commentId}`).empty();
                    $(`#bookMarkContainer-${commentId}`).append(`
 <span id="notBookmarked-${commentId}" onclick="showTagModel(${commentId},'${objectType}')" style="cursor:pointer;" class="kt-badge kt-badge--info kt-badge--inline">UnMarked</span>

`);

                }
                ,
                error: function (err) {


                }
            });
    }


    function showTagModel(commentId, objectType) {

        $(".tag-div").hide();




        if (objectType != "Customer" && objectType != "ZestItem") {
            $(`#bookMarkContainer-${commentId}`).append(`

<div class="card tag-div" id="tag-div-${commentId}" style="position: absolute; top: -40px; right: 390px; z-index: 100; width: 500px;">
														<div class="card-header kt-font-bolder kt-bg-fill-primary" style="padding:10px">
															Remark
														</div>
														<div class="card-body" style="background-color:#eae3fb8c;">
<div class="form-group">
<label>Remark:</label>
															<input id="tag-input-${commentId}" type="text" style="display:block;" class="form-control" />
</div>
<div class="form-group">
       <button type="button" onclick="toggelOptionalDiv('${commentId}')" class="btn btn-sm btn-primary">More Options</button>
    </div>
<div id="optional-${commentId}" style="display:none;">
    <div class="form-group">
        <label>User:</label>
        <input id="userId-${commentId}"  style="width: 100%;" />
    </div>
    <div class="form-group">
        <label style="display:block;">Time Type:</label>

        <input type="radio" id="Hours-${commentId}" name="timetype-${commentId}" value="Hours">
<label for="Hours">Hours</label><br>
<input type="radio" id="Days-${commentId}" name="timetype-${commentId}" value="Days">
<label for="Days">Days</label><br>
<input type="radio" id="Weeks-${commentId}" name="timetype-${commentId}" value="Weeks">
<label for="Weeks">Weeks</label><br>
    </div>
        <div class="form-group">
        <label>Time:</label>

            <input class="form-control" type="number" min="1" value="1" id="timeVal-${commentId}" />
       </div>
</div>
<button onclick="addBookMark(${commentId},'${objectType}')" class="btn btn-primary" type="button">Ok</button>
            <button onclick="cancelAddBookMark(${commentId})" class="btn btn-primary" type="button">Cancel</button>
														</div>

													</div>




`);

            $(`#userId-${commentId}`).kendoDropDownList({
                filter: "contains",
                autoBind: true,
                optionLabel: "Select User...",
                dataTextField: "FullName",
                dataValueField: "Id",
                dataSource: {
                    type: "json",
                    serverFiltering: true,

                    transport: {
                        read: {
                            url:"@Url.Action("GetUsers", "Account")",
                            data: function (e) {
                                var filterText = $(`#userId-${commentId}`).getKendoDropDownList().filterInput.val();

                                return { text: filterText }
                            }}
                    }
                }
            }).data("kendoDropDownList");

        } else {
            $(`#bookMarkContainer-${commentId}`).append(`

<div class="card tag-div" id="tag-div-${commentId}" style="position: absolute; top: -40px; right: 390px; z-index: 100; width: 500px;">
														<div class="card-header kt-font-bolder kt-bg-fill-primary" style="padding:10px">
															Remark
														</div>
														<div class="card-body" style="background-color:#eae3fb8c;">
<div class="form-group">
<label>Remark:</label>
															<input id="tag-input-${commentId}" type="text" style="display:block;" class="form-control" />
</div>

<button onclick="addBookMark(${commentId},'${objectType}')" class="btn btn-primary" type="button">Ok</button>
            <button onclick="cancelAddBookMark(${commentId})" class="btn btn-primary" type="button">Cancel</button>
														</div>

													</div>




`);


        }

        $(`#tag-div-${commentId}`).fadeIn();

    }

    function toggelOptionalDiv(commentId) {
        $(`#optional-${commentId}`).toggle();
    }


    function addBookMark(commentId, objectType) {

        var userId = "";
        var timeType = "";
        var timeVal = "";
        if (objectType != "Customer" && objectType != "ZestItem") {
            userId= $(`#userId-${commentId}`).data("kendoDropDownList").value();
            var timeTypeRadio = document.getElementsByName(`timetype-${commentId}`);
            for (var i = 0, length = timeTypeRadio.length; i < length; i++) {
                if (timeTypeRadio[i].checked) {
                    // do whatever you want with the checked radio
                    timeType = timeTypeRadio[i].value;
                    // only one radio can be logically checked, don't check the rest
                    break;
                }
            }
            timeVal = $(`#timeVal-${commentId}`).val();
        }




        if (userId != "") {
            if (timeType == "") {
                onJSError("Please select Time Type!!");
                return;
            }

            if (timeVal == "" || timeVal == "0" || timeVal == 0) {
                onJSError("Please enter the Time!!");
                return;
            }
        }



        var data = {
            commentId: commentId,
            tag: $(`#tag-input-${commentId}`).val(),
            userId: userId,
            timeType: timeType,
            timeVal: timeVal
        };



        $.ajax({
            type: 'POST',
            url: "@Url.Action("AddBookMarkNote", "StickyNote", new { @Area = "" })",
            data: data,
            dataType: 'json',
            success: function (data) {

                if (data != false) {
                    $(`#tag-div-${commentId}`).hide();

                    $(`#bookMarkContainer-${commentId}`).empty();
                    $(`#bookMarkContainer-${commentId}`).append(`
<span id="bookmarked-${commentId}" onclick="removeBookMark(${commentId},'${objectType}')" style="cursor:pointer;" class="kt-badge kt-badge--danger kt-badge--inline">Marked</span>
`);
                }
                else
                    onJSError("Choosen User in Bookmark has no permission to see this page!! ");
            }
            ,
            error: function (err) {


            }
        });
    }


    function cancelAddBookMark(commentId) {
        //$(`#bookMarkContainer-${commentId}`).empty();
        $(`#tag-div-${commentId}`).remove();
    }


        function toggelReplaies(commentId) {
            $(`#replat-container-${commentId}`).toggle();
            // $(`#reply-bolck-${commentId}`).toggle();
        }

        function ShowReplayInput(commentId) {
            $(`#replay-input-div-${commentId}`).toggle();
            // $(`#replat-container-${commentId}`).toggle();
            var recordReplyButton = document.getElementsByClassName("recordReplyButtonClass");
            for (var i = 0; i < recordReplyButton.length; i++) {
                recordReplyButton[i].addEventListener("mousedown", startReplyRecording);
                recordReplyButton[i].addEventListener("mouseup", stopReplyRecording);
            }
        }
    function DeleteVoice(commentId, ObjectType, ObjectTag, ObjectId, channel) {

        var data = {
            id: commentId
        };
               $.ajax({
                type: 'POST',
                url: "@Url.Action("Delete", "StickyNote", new { @Area = "" })",
                data: data,
                //dataType: 'json',
                   success: function (response) {
                       if (response == "Success") {
                           StickyNotesload(ObjectType, ObjectId, ObjectTag, channel); //HERE
                           ShowSuccessfllyMsg("@NotesResource.VoiceDeleted");
                       } else {
                           onJSError("@NotesResource.DeleteVoiceFeild");
                       }


                }
                ,
                   error: function (response) {

                           onJSError("@NotesResource.DeleteVoiceFeild");

                }
            });
    }
        function onKeyUpHandler(postId, parentId) {

            if (event.keyCode == 13 && event.shiftKey) {


            } else if (event.keyCode == 13) {
                if (parentId == null)
                    $(`#send-btn-${postId}`).click();
                else
                    $(`#send-replay-btn-${parentId}`).click();
            }
        }




         function addComment(EntityType, ObjectId, objectTag, userImg, InptId,parentId,chanal) {

             debugger;
        var msg = "";
        if (parentId == null) {
            msg = $(`#cmnt-inpt-${InptId}`).val();
            $(`#cmnt-inpt-${InptId}`).attr("disabled", "disabled");

        } else {
            msg = $(`#replay-input-${parentId}`).val();
            $(`#replay-input-${parentId}`).attr("disabled", "disabled");

        }

        if (msg.trim() == '') {
            onJSError("@NotesResource.Empty");
        } else {

            var channel = 0;
            if (chanal == '@ChannelEnum.General')
                channel = 0;
            else
                channel = 1;

            var data = {
                objectType: EntityType
                , objectId: ObjectId
                , objectTag: objectTag
                , Channel: channel
                , note: msg.trim(),
                parantId: parentId
            };
            //var sendbtn = $('#send-replay-btn-' + channel);
            //sendbtn.attr("disabled", "disabled");



            $.ajax({
                type: 'POST',
                url: "@Url.Action("AddNote", "StickyNote", new { @Area = "" })",
                data: data,
                dataType: 'json',
                success: function (data) {
                    StickyNotesload(EntityType, ObjectId, objectTag, channel);
                  //  sendbtn.removeAttr("disabled");

                }
                ,
                error: function (err) {
                    StickyNotesload(EntityType, ObjectId, objectTag, channel);
                    //sendbtn.removeAttr("disabled");
                    //$(`#cmnt-counts-${InptId}`).text(commentCount);
                    //$(`#cmnt-inpt-${InptId}`).removeAttr("disabled");
                    //onJSError("Adding Comment failed");

                }
            });
        }




    }
        function UploadReplyVoiceNote(formData,parentId) {

        $.ajax({
            type: "POST",
            url: '/StickyNote/Upload',
            data: formData,
            // dataType: 'json',
            contentType: false,
            processData: false,
            success: function (response) {

                var channel = datachannelreply;
                var data = {
           objectType: ObjectType
            , objectId: ObjectId
            , objectTag: ObjectTag
                , Channel: channel
                , note: response,
                parantId: parentId,
                isVoice:true
            };
                  $.ajax({
                type: 'POST',
                url: "@Url.Action("AddNote", "StickyNote", new { @Area = "" })",
                data: data,
                //dataType: 'json',
                success: function (data) {
                                    StickyNotesload(ObjectType,ObjectId,ObjectTag,channel); //HERE
                    ShowSuccessfllyMsg("@NotesResource.VoiceAdded");

                }
                ,
                error: function (err) {

                    onJSError("@NotesResource.VoiceField");

                }
            });
            },
            error: function (error) {

                alert("errror");
            },

        });

    }




</script>
