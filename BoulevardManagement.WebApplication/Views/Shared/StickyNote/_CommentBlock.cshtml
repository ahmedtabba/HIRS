                                        <img class="img-circle img-sm" src="@Model.Comments[i].ChildComments[j].UserPhoto" alt="User Image">
                                    </span>
                                </div>
                                <div class="kt-notes__content" style="border:5px @(Model.Comments[i].ChildComments[j].UserColor) solid; background-color:@(Model.Comments[i].ChildComments[j].UserColor)17; border-radius:25px;">
                                    <div class="kt-notes__section">
                                        <div class="kt-notes__info">
                                            <a href="#" class="kt-notes__title">
                                                @*@if (Model.Comments[i].ChildComments[j].UserColor != null)
            {
                <span data-toggle="kt-tooltip" title="" data-placement="top" style="vertical-align: middle;display: inline-block;width: 20px;height: 20px;border-radius: 50%;background-color:@Model.Comments[i].ChildComments[j].UserColor"></span>

            }*@
                                                @Model.Comments[i].ChildComments[j].UserFullName
                                            </a>
                                            <span class="kt-notes__desc badge badge-secondary" style="color: #414b4c; margin:0 5px;">
                                                @Model.Comments[i].ChildComments[j].Duration.Split('|')[0]
                                            </span>
                                            <span class="kt-notes__desc badge badge-secondary" style="color: #414b4c; margin: 0 5px;">
                                                @Model.Comments[i].ChildComments[j].Duration.Split('|')[1]
                                            </span>

                                        </div>
                                        <div class="">

                                            @if (Model.Comments[i].ChildComments.Count > 0 && Model.Comments[i].ChildComments[j].StickyNoteMessageType == StickyNoteMessageTypeEnum.VoiceMessageNote && Model.Comments[i].ChildComments[j].CreatedBy == User.Identity.GetId() && User.IsInRole(RoleConsistent.StickyNote.Delete))
                                            {
                                                <a href="javascript:void(0);" class="btn btn-sm btn-icon-md btn-icon ChatReplySection">
                                                    <span onclick="DeleteVoice(@Model.Comments[i].ChildComments[j].Id,'@Model.Comments[i].ObjectType','@Model.Comments[i].ObjectTag','@Model.Comments[i].ObjectEncriptedId','@((int)Model.Comments[i].Channel)')" style="cursor: pointer;">  <i class="flaticon2-trash kt-font-brand"></i></span>
                                                </a>
                                            }



                                        </div>
                                    </div>


                                    <span class="kt-notes__body" style="color: #414b4c">
                                        @if (Model.Comments[i].ChildComments[j].StickyNoteMessageType == StickyNoteMessageTypeEnum.VoiceMessageNote)
                                        {

                                            if (User.IsInRole(RoleConsistent.StickyNote.DownloadRecord))
                                            {

                                                @Html.Raw(Model.Comments[i].ChildComments[j].Note.Replace("\n", "<br>"))

                                            }
                                            else
                                            {
                                                var record = Model.Comments[i].ChildComments[j].Note.Replace("<audio controls=''", "<audio controls='' controlsList='nodownload'");
                                                @Html.Raw(record.Replace("\n", "<br>"))

                                            }

                                        }
                                        else
                                        {
                                            @Html.Raw(Model.Comments[i].ChildComments[j].Note.Replace("\n", "<br>"))

                                        }
                                    </span>
                                </div>
                            </div>
                        }
                    </div>







                    <div id="replay-input-div-@Model.Comments[i].Id" style="margin-top:10px; margin-bottom:10px; display:none;">



                        <div class="img-push">
                            <input hidden />
