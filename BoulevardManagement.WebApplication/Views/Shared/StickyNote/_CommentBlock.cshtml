                                <textarea class="form-control send-input" style="width:100%;" rows="3" id="replay-input-@Model.Comments[i].Id" placeholder="@NotesResource.TypeReply"
                                          onkeyup="onKeyUpHandler('@Model.Comments[i].ObjectId',@Model.Comments[i].Id)"></textarea>
                                <input hidden id="parentIdHolder" value=null />
                            </div>
                            <div class="row" style="margin-bottom:50px;">
                                <div class="col">
                                    <button type="button" id="send-replay-btn-@Model.Comments[i].Id"
