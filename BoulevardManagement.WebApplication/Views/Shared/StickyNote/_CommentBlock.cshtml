                                <a href="javascript:void(0);" class="btn btn-sm btn-icon-md btn-icon ChatReplySection">
                                    <span onclick="ShowReplayInput(@Model.Comments[i].Id)" style="cursor: pointer;">  <i class="flaticon-reply kt-font-brand"></i></span>
                                </a>
