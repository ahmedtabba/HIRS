                                    {
                                        <button type="button" id="send-voice-btn-@Model.Comments[i].Id" data-parentId="@Model.Comments[i].Id" data-objecttype="@Model.Comments[i].ObjectType" data-objecttag="@Model.Comments[i].ObjectTag" data-objectid="@Model.Comments[i].ObjectEncriptedId" data-channelid="@((int)Model.Comments[i].Channel)"
                                                class="recordReplyButtonClass recbutton pull-right" style="margin:0 10px !important;">
                                        </button>
                                    }
                                    @*@if (true)
                                        {
                                            <button type="button" id="send-voice-btn-@Model.Comments[i].Id" data-parentId="@Model.Comments[i].Id" data-objecttype="@Model.Comments[i].ObjectType" data-objecttag="@Model.Comments[i].ObjectTag" data-objectid="@Model.Comments[i].ObjectEncriptedId" data-channelid="@((int)Model.Comments[i].Channel)"
                                                    class="recordReplyButtonClass recbutton " style="margin-left:0px !important;">
                                            </button>
                                        }*@

