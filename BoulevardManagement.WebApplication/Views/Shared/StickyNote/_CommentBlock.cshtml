
@using BoulevardManagement.WebApplication.Models.StickyNote;
@using BoulevardManagement.WebApplication.Resources;

@using BoulevardManagement.DTO;
@model CommentsVM



<style>
    .kt-notes .kt-notes__items .kt-notes__item .kt-notes__content:after {
        position: absolute;
        content: '';
        width: 0;
        height: 0;
        top: 10px;
        right: 100%;
        margin-right: -3.5rem;
        border-right: solid 10px #F7F8FC;
        border-bottom: solid 17px transparent;
        border-left: solid 17px transparent;
        border-top: solid 17px transparent;
        display: none !important;
    }

    .recbutton {
        width: 35px;
        height: 35px;
        // background-color: red;
        border: 0;
        border-radius: 35px;
        background-image: url('/assets/media//icons/record-btn.png');
        background-size: contain;
        outline: none;
    }

    .recbutton-sm {
        width: 10px;
        height: 10px;
        border: 0;
        border-radius: 35px;
        background-image: url('/assets/media//icons/record-btn.png');
        background-size: contain;
        outline: none;
    }

    .notRec {
        //background-color: darkred;
    }

    .Rec {
        animation-name: pulse;
        animation-duration: 1.5s;
        animation-iteration-count: infinite;
        animation-timing-function: linear;
    }

    @@keyframes pulse {
        0% {
            box-shadow: 0px 0px 5px 0px rgba(173,0,0,.3);
        }

        65% {
            box-shadow: 0px 0px 5px 13px rgba(173,0,0,.3);
        }

        90% {
            box-shadow: 0px 0px 5px 13px rgba(173,0,0,0);
        }
    }

    .send-input {
        width: 91%;
        display: inline-block;
    }

    /*.box-comments .box-comment:first-of-type {
        padding-top: 5px;
    }

    .box-comments {
        /*background-color: #66666630;*/
    /* background-color: #d0d0d014;
    }

    */

    .send-btn {
        /*display: none;*/
        margin: 0 0 4px 4px;
        position: absolute;
    }

    .multiline {
        white-space: pre-line;
        margin-top: -10px;
    }


    textarea {
        resize: none;
    }

    @@media only screen and (max-width: 600px) {
        audio {
            width: 190px;
            height: 50px;
        }
    }

    @@media only screen and (max-width: 400px) {
        audio {
            width: 100px;
            height: 30px;
        }
    }
</style>


@{
    var UserColor = ViewBag.UserColor;
}




@********************************************************************************************************@
<div class=" box-comments">
    <div class="kt-notes">
        <div class="kt-notes__items" id="cmnt-box">
            @for (var i = 0; i < Model.Comments.Count; i++)
            {




                <div class="kt-notes__item box-comment" id="new-cmnt-@Model.Comments[i].Id">
                    <div class="kt-notes__media">
                        <span class="kt-notes__icon">
                            <img class="img-circle img-sm" src="@Model.Comments[i].UserPhoto" alt="User Image">
                        </span>
                    </div>
                    <div class="kt-notes__content" style="border:5px @(Model.Comments[i].UserColor) solid; background-color:@(Model.Comments[i].UserColor)17; border-radius:25px;">
                        <div class="kt-notes__section">
                            <div class="kt-notes__info">
                                <a href="#" class="kt-notes__title">
                                    @*@if (Model.Comments[i].UserColor !=null)
            {
                <span data-toggle="kt-tooltip" title="" data-placement="top" style="vertical-align: middle;display: inline-block;width: 20px;height: 20px;border-radius: 50%;background-color:@Model.Comments[i].UserColor"></span>

            }*@

                                    @Model.Comments[i].UserFullName

                                </a>
                                <span class="kt-notes__desc badge badge-secondary" style="color: #414b4c; margin: 0 5px;">
                                    @Model.Comments[i].Duration.Split('|')[0]
                                </span>
                                <span class="kt-notes__desc badge badge-secondary" style="color: #414b4c; margin: 0 5px;">
                                    @Model.Comments[i].Duration.Split('|')[1]
                                </span>


                            </div>
                            <div class="">
