                    </div>
                </div>


                <!--Reply Block-->
                <div id="reply-bolck-@Model.Comments[i].Id" style=" padding-right:30px; padding-left:50px;">
                    <div id="replat-container-@Model.Comments[i].Id">
                        @for (var j = 0; j < Model.Comments[i].ChildComments.Count; j++)
                        {
                            <div class="kt-notes__item box-comment" id="new-cmnt-@Model.Comments[i].ObjectId-@Model.Comments[i].ChildComments[j].Id ">
