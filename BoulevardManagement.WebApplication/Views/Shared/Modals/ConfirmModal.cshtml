@model BoulevardManagement.WebApplication.Models.ConfirmModel

<div class="modal modal-warning fade" id="@Model.ModelId" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" style="z-index:2000">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" id="Close@(Model.ButtonId)">
                    <i class="fa fa-close" aria-hidden="true"></i>
                </button>
                <h4 class="modal-title"><i class="fa fa-warning"></i>&nbsp;@Model.Title</h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12" id="Content@(Model.ModelId)">

                        @Model.Content
                    </div>
                    <!-- /.col -->
                </div>
                <!-- /.row -->
            </div>
            <div class="modal-footer">
                <button type="button" id="@Model.ButtonId" class="btn btn btn-outline" data-dismiss="modal">@Model.ButtonTextOk</button>
                <button type="button" id="Cancle@(Model.ButtonId)" class="btn btn btn-outline pull-right" data-dismiss="modal">@Model.ButtonTextCancel</button>

            </div>
        </div>
        <!-- /.modal-content -->
    </div>
</div>

