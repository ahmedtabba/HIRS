@using BoulevardManagement.DTO
@using BoulevardManagement.WebApplication.Resources

<div class="modal" id="create-zoom-meet-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@CommonResource.MeetTopic</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
                <div class="modal-body">
                    <div class="row ">
                        <div class="col-lg-12 form-group">
                            <input hidden id="caseId" />
                            <input hidden id="caseType" />
                            <label class="form-label">@CommonResource.MeetTopic</label>
                            <input class="form-control" id="topic" />
                        </div>


                    </div>
                </div>
                <div class="modal-footer">
                    <button id="createBtn" type="button" class="btn btn-primary">@CommonResource.Add</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@CommonResource.Cancel</button>
                </div>
        </div>
    </div>
</div>
<script>

    $("#createBtn").on("click", function () {
        var data = {
            topic: $("#topic").val(),
            caseId: $("#caseId").val(),
            caseType: $("#caseType").val()
        };

        $.ajax({
            type: 'POST',
            url: "@Url.Action("CreateZoomMeeting", "Zoom", new { @Area = "" })",
            data: data,
            success: function (response) {
                $("#create-zoom-meet-modal").modal("hide");
                window.open(response.res, '_blank');
            }
        });
    });

</script>