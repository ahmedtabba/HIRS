@using BoulevardManagement.DTO;
@using BoulevardManagement.Model.Entities;
@using BoulevardManagement.WebApplication.Utilities;
@using BoulevardManagement.WebApplication.Resources;
@model IQueryable<UserNotificationDTO>
<style>

     .list-group-item1 {
        position: relative;
        display: block;
        padding: 0.75rem 1.25rem;
        margin-bottom: -1px;
    }

    #kt_tab_table_5_3::-webkit-scrollbar-track {
        -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,0.3);
        border-radius: 10px;
        background-color: #F5F5F5;
    }

    #kt_tab_table_5_3::-webkit-scrollbar {
        width: 6px;
        background-color: #F5F5F5;
    }

    #kt_tab_table_5_3::-webkit-scrollbar-thumb {
        border-radius: 10px;
        -webkit-box-shadow: inset 0 0 6px rgba(0,0,0,.3);
        background-color: #ef4849;
    }
</style>

<div class="tab-pane fade show active" id="kt_tab_table_5_3" role="tabpanel" aria-labelledby="kt_tab_table_5_3" style="max-height:600px;overflow-y:scroll">
    <!--begin::Table-->
    <div class="table-responsive list-group-item1">
        <table class="table table-borderless table-vertical-center">
            <thead>
                <tr>
                    <th class="p-0 w-50px"></th>
                    <th class="p-0 min-w-150px">@NotificationResource.Message</th>
                    <th class="p-0 min-w-100px">@NotificationResource.Date</th>
                    <th class="p-0 min-w-125px">@NotificationResource.Type</th>

                </tr>
            </thead>
            <tbody>
                @foreach (var Notification in Model)
                {
                    <tr>
                        <td class="pl-0 py-5">
                            <div class="symbol symbol-45 symbol-light mr-2">
                                @*<img src="assets/media/svg/misc/006-plurk.svg" class="h-50 align-self-center" alt="">*@
                                @Html.Raw(Notification.ObjectTypeIcon)
                            </div>
                        </td>
                        <td class="pl-0 ml-n3">
                            <a href="@Notification.NotificationURL" target="_blank" class="text-dark-75 font-weight-bolder text-hover-primary mb-1 font-size-lg">@Notification.NotificationString</a>
                        </td>
                        <td style="padding:0px">
                            <span class="text-dark-75 font-weight-bolder d-block font-size-lg">@Notification.CreationDate.ToString("dd/MM/yyyy")</span>

                        </td>
                        <td style="padding:0px">
                            <span class="text-dark-75 font-weight-bolder d-block font-size-lg">@Html.Raw(Notification.ObjectTypeString)</span>
                        </td>

                    </tr>
                }


            </tbody>
        </table>
        @if (Model.Count() == 0)
        {
            <div class="" style="text-align:center; vertical-align:central; padding:25px;">
                <h5 class="text-primary">@NotificationResource.NoNotifications</h5>
            </div>
        }
    </div>
    <!--end::Tablet-->
</div>


