@using BoulevardManagement.WebApplication.Models
@using BoulevardManagement.WebApplication.Resources;
@model LoginViewModel

@{
    Layout = "~/Views/Shared/_Layout-Login.cshtml";
}

<style>
 

  

    .ptb-100 {
        padding-top: 100px !important;
        padding-bottom: 100px !important;
    }

    .sign-in-form {
        background: #ffffff  !important;
        -webkit-box-shadow: 0 2px 48px 0 rgba(0, 0, 0, 0.08)  !important;
        box-shadow: 0 2px 48px 0 rgba(0, 0, 0, 0.08)  !important;
        padding: 40px  !important;
        border-radius: 5px  !important;
        max-width: 600px  !important;
        margin: auto  !important;
    }

    form {
        display: block !important ;
        margin-top: 0em !important ;
    }

   

    .sign-in-form .sign-in-title {
        text-align: center !important ;
        margin-bottom: 30px !important ;
    }

        .sign-in-form .sign-in-title h3 {
            font-size: 30px !important ;
            font-family: "Roboto", sans-serif !important ;
            margin-bottom: 8px !important ;
        }

        .sign-in-form .sign-in-title p {
            margin-bottom: 30px !important ;
        }

    .sign-in-form form .form-control {
        height: 50px !important ;
        border: 1px solid #eeeeee !important ;
        border-radius: 3px !important ;
        color: #2f4858 !important ;
        padding-left: 20px !important ;
        background: transparent !important ;
    }

        .sign-in-form form .form-control:focus {
            border-color: #207ef7 !important ;
            outline: 0 !important ;
            -webkit-box-shadow: none !important ;
            box-shadow: none !important ;
        }

        .sign-in-form form .form-control::-webkit-input-placeholder {
            color: #666666 !important ;
        }

        .sign-in-form form .form-control:-ms-input-placeholder {
            color: #666666 !important ;
        }

        .sign-in-form form .form-control::-ms-input-placeholder {
            color: #666666 !important ;
        }

        .sign-in-form form .form-control::placeholder {
            color: #666666 !important ;
        }

    .sign-in-form form .form-check {
        margin-top: 18px !important ;
    }

        .sign-in-form form .form-check .form-check-label {
            color: #666666 !important ;
            position: relative !important ;
            top: -2px !important ;
            z-index: 1 !important ;
        }

    .sign-in-form form .form-check-input {
        margin-top: 3px !important ;
    }

    .sign-in-form form .send-btn {
        margin-top: 20px !important ;
    }

        .sign-in-form form .send-btn .default-btn {
            color: #ffffff !important ;
        }

    .sign-in-form form span {
        display: block !important ;
        color: #777777 !important ;
    }

        .sign-in-form form span a {
            color: #207ef7 !important ;
        }

    .sign-in-form .forgot-password {
        margin-bottom: 0 !important ;
        margin-top: -25px !important ;
    }

        .sign-in-form .forgot-password a {
            color: #777777 !important ;
        }

            .sign-in-form .forgot-password a:hover {
                color: #207ef7 !important ;
            }
    .h1, .h2, .h3, .h4, .h5, .h6, h1, h2, h3, h4, h5, h6 {
        color: #2f4858;
        text-transform: capitalize;
        font-family: "Rubik", sans-serif;
        font-weight: bold;
    }
    .default-btn {
        border: none;
        position: relative;
        display: inline-block;
        text-align: center;
        overflow: hidden;
        z-index: 1;
        text-transform: capitalize;
        background-color: #ef4849;
        color: #ffffff;
        -webkit-transition: 0.5s;
        transition: 0.5s;
        border-radius: 30px;
        opacity: 1;
        font-weight: 400;
        font-size: 15px;
        padding-left: 30px;
        padding-right: 30px;
        padding-top: 14px;
        padding-bottom: 14px;
    }
        .default-btn:hover {
            color: #ffffff !important;
            background-color: #2f4858
        }
</style>

@{ 
    var dir = "ltr";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        dir = "rtl";
    }
}
<div class="sign-in-area ptb-100">
    <div class="container">
        <div class="sign-in-form">
            <div class="sign-in-title">
                <img src="~/Content/img/uossm-01.png" style="height:100px" />
            </div>
            <div class="sign-in-title">
                <h3>@LoginResource.LoginTitle!</h3>
                <p style="color:grey">@LoginResource.Descreption</p>
            </div>
            @using (Html.BeginForm("Login", "Account", new { ReturnUrl = ViewBag.ReturnUrl }, FormMethod.Post, new { @class = "form-horizontal", role = "form" }))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                <input hidden name="RememberMe" id="RememberMe" value="fulse" />

                <div class="row">
                    <div class="col-lg-12">
                        <div class="form-group">
                            <input type="email" class="form-control" placeholder="@LoginResource.Email" name="email" id="email" style="direction:@dir" >
                            @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="col-lg-12">
                        <div class="form-group">
                            <input type="password" class="form-control" placeholder="@LoginResource.Password"  name="Password" id="Password" style="direction:@dir">
                            @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                        </div>
                    </div>

               

                

                    <div class="col-lg-12">
                        <div class="send-btn">
                            <button type="submit" href="#" class="default-btn" style="@(System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft?"float:right":"float:left")">
                                @LoginResource.LoginBtn
                                <span></span>
                            </button>
                        </div>
                        <br>
                    </div>
                </div>
            }



        </div>
    </div>
</div>
