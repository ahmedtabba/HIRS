<script type="text/javascript">

    var selectedActions = [];
    var FormType = "";
    $(function () {


        $("#EditUserBtn").on("click", function () {

            debugger;

            FormType = "SaveAndNew";
            EditFunction();
        });



    });

    $("#EditSave").click(function (e) {
        debugger;
        FormType = "Save";
        EditFunction();
    });
    $("#EditSaveAndContinue").click(function (e) {
        debugger;
        FormType = "SaveAndContinue";
        EditFunction();
    });
    function EditFunction() {
        debugger;
        if ('@Model.Id' !== "" && '@((string)ViewBag.CurrentUserId)' == '@Model.Id') {
            var selectedItmes = $("#sortable-listD>.list-item");

            for (var i = 0; i < selectedItmes.length; i++) {
                selectedActions.push(selectedItmes[i].getAttribute("id"));
            }
            $.ajax({
                type: 'POST',
                data: {
                    selectedActions: selectedActions
                },
                url: "/Home/UpdateQuickAction",
                success: function (d) {

                }

            });
        }

        $("#FormType").val(FormType);
        $('#RegisterForm').submit();
    }
    $("#AddUserBtn").click(function (e) {
        debugger;
        FormType = "SaveAndNew";
        SetFileUploadInfo();
    });

    $("#AddSave").click(function (e) {
        debugger;
        FormType = "Save";
        SetFileUploadInfo();
    });
    $("#AddSaveAndContinue").click(function (e) {
        debugger;
        FormType = "SaveAndContinue";
        SetFileUploadInfo();
    });

    function SetFileUploadInfo() {
        debugger;
        if (UploadedFile)
            $('#filename').val(UploadedFile)

        if (UploadedFilePath)
            $('#filePath').val(UploadedFilePath)
         $("#FormType").val(FormType);
        $('#RegisterForm').submit();
    }

    function onSuccessUploadSampleFile(e) {
        debugger;
        UploadedFile = getFileInfo(e);
        UploadedFilePath = e.response.filePath;
        if (UploadedFile)
            $('#HasNewAttachment').val(true);
    }

    function getResource(name) {
        debugger;
        if (name == 'FileUploadPath')
            return '@TempAttchmentFolder.Replace("\\","\\\\")';

        return '';
    }


</script>



