<!--Temp-->
<style>

    #kt_footer {
        position: fixed;
        bottom: 0;
        width: 100%;
    }

    #profile.dragging {
        background-image: none !important;
    }

    #PhotoURL {
        position: absolute;
        top: -1000px;
    }




    #example {
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
    }

    .demo-section {
        padding: 50px 70px;
    }

    .list-wrapper {
        overflow: hidden;
        display: flex;
        justify-content: space-between;
    }

    #sortable-listA, #sortable-listB, #sortable-listC, #sortable-listD {
        width: 210px;
        min-height: 40px;
        margin: 0;
        padding: 0;
        border: 1px solid #dddddd;
        border-radius: 4px;
    }

    .list-item {
        list-style-type: none;
        width: 200px;
        margin: 5px;
        line-height: 30px;
        text-align: center;
        background-color: #222222;
        color: #ffffff;
        border-radius: 3px;
    }

    #sortable-listA .list-item {
        background-color: #dddddd;
        color: #000000;
    }

    #sortable-listB .list-item {
        background-color: #ff879e;
        color: #000000;
    }

    #sortable-listC .list-item {
        background-color: #dddddd;
        color: #000000;
    }

    #sortable-listD .list-item {
        background-color: #ef4849;
        color: #fff;
    }

    #placeholder.list-item {
        background-color: #ffffff;
        color: #777;
    }
</style>
