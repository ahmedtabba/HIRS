                success: function (data) {
                    if (data)
                        alert(data);

                    $("#del-photo-btn").hide();

                }
            });

    }
</script>


<script>
    $(function () {
        onJobRoleChange();
        $("#save").click(function () {

            console.log('save clicked')



            if ($("#PhotoURL").val() != "") {

                //check if the image extension is valid
                var fileName1 = document.getElementById("PhotoURL").value;

                var extensionImg = fileName1.substr(fileName1.lastIndexOf('.') + 1);

                var validExtensions = ["jpg"/*, "png", "bmp", "gif", "svg"*/];

                if ($.inArray(extensionImg, validExtensions) == -1) {
                    $(".error-div").removeAttr("hidden");
                    return false;
                }
            }


            


        });




    });

    function onJobRoleChange() {

        if ($("#jobRole").val() == '@JobRole.IT') {
            $("[name='DepartmentId']").data("kendoDropDownList").dataSource.read();
            $("[name='DepartmentId']").data("kendoDropDownList").value("");
            $("[name='DepartmentId']").data("kendoDropDownList").enable(false);
        } else {
            $("[name='DepartmentId']").data("kendoDropDownList").dataSource.read();
            $("[name='DepartmentId']").data("kendoDropDownList").value("");
            $("[name='DepartmentId']").data("kendoDropDownList").enable(true);
        }
    }
</script>


