@using BoulevardManagement.Utilities;
@using BoulevardManagement.WebApplication.Resources;
@using BoulevardManagement.DTO;
@{
    ViewBag.Title = UsersViewResource.ShowUsers;
}
@{
    var customeClass = "";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }
     var Roles = new[] {
new { name = JobRole.IT.GetDescription(), value = 0 },
new { name = JobRole.ServiceProvider.GetDescription(), value = 1 },
new { name = JobRole.Consultant.GetDescription(), value = 2 },
};
}
<style>
    .k-rtl .k-grid td {
        position: inherit !important;
    }

    .k-grid-content .btn-group {
        position: absolute !important;
    }
</style>
<div class="container">

    <div class="card card-custom" data-card="true" id="kt_card_3">
        <div class="card-header">
            <div class="card-title">
                <h3 class="card-label">@UsersViewResource.Users</h3>
            </div>
            <div class="card-toolbar">
                <a href="javascript:void(0);" onclick=" $('.k-grid-excel').trigger('click');" data-toggle="tooltip" title="@CommonResource.ExportExcelTooltip" class="btn btn-icon btn-circle btn-sm btn-light-skype mr-1" data-card-tool="">
                    <i class="fa fas fa-file-excel icon-nm"></i>
                </a>


                <a href="@Url.Action("Register", "Account", new { @Area = "" })" class="btn btn-icon btn-circle btn-sm btn-light-facebook mr-1" data-card-tool="">
                    <i class="ki ki-plus icon-nm"></i>
                </a>
                <a href="javascript:void(0);" onclick="$('.k-i-refresh').click();" class="btn btn-icon btn-circle btn-sm btn-light-success mr-1" data-card-tool="reload">
                    <i class="ki ki-reload icon-nm"></i>
                </a>
                <a href="javascript:void(0);" class="btn btn-icon btn-circle btn-sm btn-light-primary mr-1" data-card-tool="toggle">
                    <i class="ki ki-arrow-down icon-nm"></i>
                </a>
            </div>
        </div>
        <div class="card-body" kt-hidden-height="471" style="">
            <div class="@customeClass" id="ControlRegion">
                @(Html.KendoGrid<BoulevardManagement.WebApplication.Models.UsersViewModel>()
                        .Name("UserGrid")
                        .Columns(columns =>
                        {
                        columns.Bound(c => c.FullName).Title(UsersViewResource.FullName).ClientTemplate(@"<div class='user-photo' style='background-image: url(" + @Url.Content("#:PhotoUrl#") + ");'></div><div class='user-name'>#: FullName #</div>").Width(220);
                        columns.Bound(c => c.Email).Title(UsersViewResource.Email_UseName).Width(200);
                        columns.ForeignKey(p => p.JobRole, Roles, "value", "name").Title(UsersViewResource.JobRole).ClientTemplate("#: JobRoleDescription #").Groupable(true).Width(150);
                        columns.Bound(c => c.DepartmentName).Title(UsersViewResource.Department).Width(100);
                        columns.Bound(c => c.IsLockedOut).Title(UsersViewResource.Diabled).ClientTemplate("#if (IsLockedOut) {# " + "Yes" + "#}else{#" + "No" + "#}#").Width(90);
                        columns.Bound(c => c.GroupNames).Title(UsersViewResource.Groups).Width(130);
                        columns.Bound(c => c.NotificationGroupsNames).Title(UsersViewResource.NotificationGroups).Width(130);
                        columns.Bound(c => c.CreationDate).Title(UsersViewResource.CreationDate).Filterable(c => c.Cell(x => x.Template("datePicker")).Operators(x => x.ForDate(d => d.IsEqualTo("equal")))).Width(150).Format(@"{0:dd/MM/yyyy}");


                        columns.Command(command =>
                        {
                            //columns.Template(@<text></text>).ClientTemplate("#=someFuntion(id)#").Title("");
                            //columns.Template(@<text></text>).ClientTemplate("<a href='" + Url.RouteUrl("Default", new { controller = "Manage", action = "ResetPasswordByManager" }) + "?Id=#=Id#' class='k-button k-button-icontext'><span class='k-icon k-i-password'></span>Reset PWD</a> <a href='" + Url.RouteUrl("Default", new { controller = "Account", action = "Register" }) + "?Id=#=Id#' class='k-button k-button-icontext'><span class='k-icon k-i-edit'></span>Edit</a>");
                            command.Custom("Show Permissions").Click("ShowPermissions").Text("Permissions");
                            command.Custom("Change Group").Click("ChangeGroup").Text("<span class='fa fa-user-circle'></span>Groups");
                            command.Custom("Change Photo").Click("ChangePhoto").Text("<span class='fa fa-image'></span>Photo");
                            command.Custom("Delete Photo").Click("DeletePhoto").Text("<span class='fa fa-image'></span>Photo");


                        }).Title("").Hidden(true);
                        columns.Command(command =>
                        {
                        columns.Template(@<text></text>).ClientTemplate("#=templateOptions(id)#").Title("").Width(80);
                        });
                                })
                                    .HtmlAttributes(new { style = "height:1000px", @id = "UserGrid" })
                                     .ToolBar(toolbar => { toolbar.Excel().HtmlAttributes(new { style = "display:none" });})
                                    .Editable(editable => { editable.Mode(GridEditMode.InLine); })
                                    .Excel(exp => exp.FileName(UsersViewResource.ShowUsers + ".xlsx").ProxyURL(Url.Action("Export_Save", "Base")).AllPages(true))
                                    .Scrollable()
                                    .Resizable(resize => resize.Columns(true))
                                    .Sortable()
                                    .Filterable(ftb => ftb.Mode(GridFilterMode.Row))
                                    .Filterable(filterable => filterable.Messages(m => m.IsFalse(GridOptionViewResource.False)).Messages(m => m.IsTrue(GridOptionViewResource.True)))
                                    .Pageable(pageable => pageable.Refresh(true).PageSizes(new List<object> { 5, 10, 20, 50, 100 }).ButtonCount(5))
                                    .ColumnMenu(c => c.Columns(true).Filterable(false))
                                    .DataSource(dataSource => dataSource
                                                .Ajax()
                                                .Model(model => model.Id(c => c.Id))
                                                //.Create(action => action.Action("Create", "Customer"))
                                                //.Update(action => action.Action("Edit", "Customer"))
                                                //.Destroy(action => action.Action("Delete", "Customer"))
                                                .Read(read => read.Action("Read", "Account"))
                                                //.Events(events => events.Error("KendoGrid_ErrorHandler"))
                                                //.Events(events => events.Error("function(e){KendoGrid_ErrorHandler(e,'CustomerGrid');}"))
                                                .PageSize(20))
    )

                @Html.Partial("_UserRoleShow", new BoulevardManagement.WebApplication.Models.UserRoleViewModel())
                @Html.Partial("_UserRole", new BoulevardManagement.WebApplication.Models.UserRoleViewModel())
                @Html.Partial("_UserGroup", new BoulevardManagement.WebApplication.Models.UserGroupViewModel())

                @Html.Partial("_UserPhoto")

            </div>
            <!--end::Tables Widget 5-->
            <!--end::Dashboard-->
            @Html.Partial("Modals/ConfirmModal", new BoulevardManagement.WebApplication.Models.DeleteConfirmModal())
        </div>
    </div>
</div>

<script type="text/javascript">
    function datePicker(args) {
        args.element.kendoDatePicker({
            format: "dd/MM/yyyy"
        });
    }



    function templateOptions(id) {
        var urlEdit = '@Url.RouteUrl("Default", new { controller = "Account", action = "Register" })' + '?Id=' + id;
        var urlRestPassword = '@Url.RouteUrl("Default", new { controller = "Manage", action = "ResetPasswordByManager" })' + '?Id=' + id;

        var result = `<div class=" ml-2"  >


<a href="#" class="btn btn-clean btn-hover-light-primary btn-sm btn-icon" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
															<span class="svg-icon svg-icon-lg">
																<!--begin::Svg Icon | path:assets/media/svg/icons/Text/Dots.svg-->
																<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
											<g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
												<rect x="0" y="0" width="24" height="24" />
												<path d="M7,3 L17,3 C19.209139,3 21,4.790861 21,7 C21,9.209139 19.209139,11 17,11 L7,11 C4.790861,11 3,9.209139 3,7 C3,4.790861 4.790861,3 7,3 Z M7,9 C8.1045695,9 9,8.1045695 9,7 C9,5.8954305 8.1045695,5 7,5 C5.8954305,5 5,5.8954305 5,7 C5,8.1045695 5.8954305,9 7,9 Z" fill="#000000" />
												<path d="M7,13 L17,13 C19.209139,13 21,14.790861 21,17 C21,19.209139 19.209139,21 17,21 L7,21 C4.790861,21 3,19.209139 3,17 C3,14.790861 4.790861,13 7,13 Z M17,19 C18.1045695,19 19,18.1045695 19,17 C19,15.8954305 18.1045695,15 17,15 C15.8954305,15 15,15.8954305 15,17 C15,18.1045695 15.8954305,19 17,19 Z" fill="#000000" opacity="0.3" />
											</g>
										</svg>
																<!--end::Svg Icon-->
															</span>
														</a>
<div class="dropdown-menu dropdown-menu-sm p-0 m-0 dropdown-menu-right">
											<ul class="navi py-5">
       <li class='navi-item'><a href="${urlEdit}" class='navi-link' target='_blank'><i class='navi-icon  flaticon2-contract'></i><span class='navi-text'>@CommonResource.Edit</span></a></li>

												<li class="navi-item">
													<a href="${urlRestPassword}" class="navi-link">
														<span class="navi-icon">
															<i class="flaticon2-writing"></i>
														</span>
														<span class="navi-text">@UsersViewResource.RestPassword</span>
													</a>
												</li>
												<li class="navi-item">
													<a href="#" class="navi-link k-grid-ChangePhoto">
														<span class="navi-icon">
															<i class="flaticon2-medical-records"></i>
														</span>
														<span class="navi-text">@UsersViewResource.ChangePhoto</span>
													</a>
												</li>
												<li class="navi-item">
													<a href="#" class="navi-link k-grid-DeletePhoto">
														<span class="navi-icon">
															<i class="flaticon2-hourglass-1"></i>
														</span>
														<span class="navi-text">@UsersViewResource.DeletePhoto</span>
													</a>
												</li>
                                                <li class='divider'></li>
                                                <li class="navi-item">
													<a href="#" class="navi-link k-grid-ShowPermissions">
														<span class="navi-icon">
															<i class="flaticon2-hourglass-1"></i>
														</span>
														<span class="navi-text">@UsersViewResource.PermissionsGranted</span>
													</a>
											   </li>
											</ul>
										</div>
									</div>`;


        return result;
    }

    $(document).ready(function ($) {
        $('#SaveUserRole').click(SubmitForm);
        $('#SaveUserGroup').click(SubmitFormGroup);
        $('#SaveUserPhoto').click(SubmitPhoto);

    });



    function SubmitForm() {
        if ($('#ChangeUserRoleForm').valid()) {
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("ChangeUserRole", "Account")',
                data: $('#ChangeUserRoleForm').serialize(),
                success: function (data) {
                    if (data)
                        alert(data);

                    var grid = $("#UserGrid").data("kendoGrid");
                    grid.dataSource.read();
                    grid.refresh();
                    $('#UserRoleModal').modal('hide');
                }
            });
        }
    }

    function SubmitFormGroup() {
        if ($('#ChangeUserGroupForm').valid()) {
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("ChangeUserGroup", "Account")',
                data: $('#ChangeUserGroupForm').serialize(),
                success: function (data) {
                    if (data)
                        alert(data);

                    var grid = $("#UserGrid").data("kendoGrid");
                    grid.dataSource.read();
                    grid.refresh();
                    $('#UserGroupModal').modal('hide');
                }
            });
        }
    }

    function SubmitPhoto() {
        SetFileUploadInfo();
        if ($('#ChangeUserPhotoForm').valid()) {
            $.ajax({
                cache: false,
                async: true,
                type: "POST",
                url: '@Url.Action("ChangeUserPhoto", "Account")',
                data: $('#ChangeUserPhotoForm').serialize(),
                success: function (data) {
                    if (data)
                        alert(data);


                    var grid = $("#UserGrid").data("kendoGrid");
                    grid.dataSource.read();
                    grid.refresh();
                    $('#UserPhotoModal').modal('hide');
                }
            });
        }
    }


    function DeletePhoto(e) {
        e.preventDefault();
        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));

        $.ajax({
            cache: false,
            async: true,
            type: "POST",
            url: '@Url.Action("DeleteUserPhoto", "Account")',
            data: { PhotoUserId: dataItem.Id},
                success: function (data) {
                    if (data)
                        alert(data);


                    var grid = $("#UserGrid").data("kendoGrid");
                    grid.dataSource.read();
                    grid.refresh();
                    $('#UserPhotoModal').modal('hide');
                }
            });

    }


    function ChangePhoto(e)
    {
        e.preventDefault();

        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        $('#PhotoUserId').val(dataItem.Id);

        $('#UserPhotoModal').modal('show');
    }

    function ChangeRole(e) {
        e.preventDefault();

        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        $('#Id').val(dataItem.Id);

        $('#UserRoleModal').modal('show');

            data = {
                roles: dataItem.RoleNames,
            }
            $.ajax({
                type: 'POST',
                url: "@Url.Action("GetUserRoles", "Account", new { @Area = "" })",
                data: data,
            dataType: 'json',
            success: function (data) {
                $("#UserRoles").data("kendoMultiSelect").value(data);
            }
        });


     //   $('#RoleId').data("kendoDropDownList").value(CommonResourceoEditnResourcesourcesourcesourcemonResourcemonResourceataItem.RoleId);

    }

    function ShowPermissions(e) {
        e.preventDefault();

        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        var baseUrl = "@Url.Action("GetPermisions")" + "/" + dataItem.Id;


        var treeViewDataSource = new kendo.data.HierarchicalDataSource({
            transport: {
                read: {
                    url: baseUrl,
                    type: "get",
                    dataType: "json"
                }
            },
            schema: {
                model: {
                    id: "Id",

                    children: "Items"

                }
            }
        });

        $("#Roles").data("kendoTreeView").setDataSource(treeViewDataSource);
        $('#UserRoleModal').modal('show');



    }

    function ChangeGroup(e) {
        e.preventDefault();

        var dataItem = this.dataItem($(e.currentTarget).closest("tr"));
        $('#userId').val(dataItem.Id);

        $('#UserGroupModal').modal('show');
        data = { groupIds: dataItem.GroupIds }

        $.ajax({
                type: 'POST',
                url: "@Url.Action("GetUserGroups", "Account", new { @Area = "" })",
                data: data,
            dataType: 'json',
            success: function (data) {
                $("#UserGroups").data("kendoMultiSelect").value(data);
            }
        });
    }

</script>
<style>
    .user-photo {
        display: inline-block;
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background-size: 32px 35px;
        background-position: center center;
        vertical-align: middle;
        line-height: 32px;
        box-shadow: inset 0 0 1px #999, inset 0 0 10px rgba(0,0,0,.2);
        margin-left: 5px;
    }

    .k-rtl .k-grid td {
        position: inherit;
    }

    .user-name {
        display: inline-block;
        vertical-align: middle;
        line-height: 32px;
        padding-left: 3px;
    }

    .k-grid-content .btn-group {
        position: absolute;
    }

    
</style>
