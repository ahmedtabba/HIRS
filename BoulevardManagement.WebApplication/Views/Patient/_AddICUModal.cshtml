@using BoulevardManagement.DTO
@using BoulevardManagement.WebApplication.Resources;
@model TeleICUDTO

@{
    var customeClass = "";
    var isRTL = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft;
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }
}

<div class="modal" id="add-icu-modal" role="dialog">
    <div class="modal-dialog" role="document">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@CommonResource.AddICUCase</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                    <span aria-hidden="true">&times;</span>
                </button>
            </div>
            @using (Html.BeginForm("Create", "TeleICU", FormMethod.Post, new { @id = "AddFormId" }))
            {
                @Html.AntiForgeryToken()
                <input hidden name="PatientId" id="PatientId" value="@Model.PatientId" />

                <div class="modal-body">
                    <div class="row ">
                        <div class="col-lg-12 form-group @customeClass">
                            <label class="form-label">@CommonResource.InvolvedServiceProviders</label>
                            @(Html.Kendo().MultiSelectFor(x=>x.InvolvedServiceProvidersIds)
          .DataTextField("FullName")
          .DataValueField("Id")
          .TagMode(TagMode.Multiple)
          .ValuePrimitive(true)
          .Placeholder(CommonResource.Select)
          .DataSource(source =>
          {
              source.Read(read =>
              {
                  read.Action("GetUsersBasedOnJobAndDepartmentId", "Account", new { JobRole = JobRole.ServiceProvider, DepartmentId = Model.PatientDepartmentId });
              }).ServerFiltering(true);
          }).Filter("contains")
          //.Events(c=>c.DataBound("dataBound"))
          .HtmlAttributes(new { @class = "form-control custom-style", @id= "InvolvedServiceProvidersIds" })
          )

                        </div>


                        <div class="col-lg-12 form-group @customeClass">
                            <label class="form-label">@CommonResource.InvolvedConsultants</label>
                            @(Html.Kendo().MultiSelectFor(x=>x.InvolvedConsultantsIds)
          .DataTextField("FullName")
          .DataValueField("Id")
          .TagMode(TagMode.Multiple)
          .ValuePrimitive(true)
          .Placeholder(CommonResource.Select)
          .DataSource(source =>
          {
              source.Read(read =>
              {
                  read.Action("GetUsersBasedOnJobAndDepartmentId", "Account", new { JobRole = JobRole.Consultant,DepartmentId=Model.PatientDepartmentId});
              }).ServerFiltering(true);
          }).Filter("contains")
          //.Events(c=>c.DataBound("dataBound"))
          .HtmlAttributes(new { @class = "form-control custom-style", @id= "InvolvedConsultantsIds" })
          )

                        </div>
                        <div class="col-lg-12 form-group @customeClass">
                            <label class="form-label">@LocationResource.Location</label>
                            @(Html.Kendo().DropDownListFor(x => x.LocationId)
                                                                    .DataTextField("Name")
                                                                    .DataValueField("Id")
                                                                    .Filter("contains")
                                                                    .OptionLabel(LocationResource.SelectLocation)
                                                                    //.Events(ev => ev.Change("onChange"))
                                                                    .DataSource(source =>
                                                                    {
                                                                        source.Read(read =>
                                                            {
                                                                read.Action("GetUnOquppiedLocationsForCurrent", "Location", new { @Area = "" })/*.Data("DataFunction")*/;
                                                            }).ServerFiltering(true);
                                                                    }).HtmlAttributes(new { @class = "form-control custom-style", @id = "LocationId", @style = "width:100%" }))
                        </div>

                    </div>
                </div>
                <div class="modal-footer">
                    <button id="saveTelICU" type="button" class="btn btn-primary">@CommonResource.Save</button>
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">@CommonResource.Close</button>
                </div>
            }
        </div>
    </div>
</div>
<script>
    $(function () {

        $("#saveTelICU").on("click", function () {
            $("#AddFormId").submit();
        });

    });
</script>