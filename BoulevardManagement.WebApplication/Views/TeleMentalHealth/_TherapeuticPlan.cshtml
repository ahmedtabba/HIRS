@{
    var customeClass = "";

    var viewMode = !User.IsInRole(RoleConsistent.TeleMentalHealth.EditTherapeuticPlan) || Model.CaseStatus == CaseStatus.Closed;
    if (Model.Id > 0)
    {
        viewMode = true;
    }
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }
}
@if (Model.CaseStatus == CaseStatus.Closed)
{
    <style>
        .k-grid-TelMHTherapeuticPlanDestroy {
            display: none !important;
        }
    </style>
}
@if (Model.Id > 0 && Model.CaseStatus != CaseStatus.Closed && User.IsInRole(RoleConsistent.TeleMentalHealth.EditTherapeuticPlan))
{
    <button type="button" id="AddFollowUpBtn" class="btn btn-primary">@TherapeuticPlanResource.AddTherapeuticPlan</button>
}
<!--begin::Form-->
@using (Html.BeginForm("SaveTelMHTherapeuticPlan", "TeleMentalHealth", FormMethod.Post, new { @id = "TelMHTherapeuticPlanFormId" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(x => x.Id)
    @Html.HiddenFor(x => x.TeleMentalHealthId)
    @Html.HiddenFor(model => model.NotesAttachmentId)
    @Html.HiddenFor(model => model.HasNotesAttachment)
    @Html.HiddenFor(model => model.NotesFilename)
    @Html.HiddenFor(model => model.NotesFilePath)
    @*@Html.HiddenFor(model => model.TherapeuticPlanVoiceAttachmentId)*@

    <input type="hidden" id="IsTherapeuticPlanVoiceDeleted" name="IsTherapeuticPlanVoiceDeleted" value="@Model.IsTherapeuticPlanVoiceDeleted" />
    <input type="hidden" id="TherapeuticPlanVoiceAttachPath" name="TherapeuticPlanVoiceAttachPath" value="@Model.TherapeuticPlanVoiceAttachPath" />


    <div class="card-header">
        <div class="card-title">
            <h3 class="card-label">

                @TherapeuticPlanResource.TherapeuticPlan


            </h3>
        </div>
        @*<div class="card-toolbar">
                <a href="#" class="btn btn-light-primary font-weight-bolder mr-2">
                    <i class="ki ki-long-arrow-back icon-sm"></i>@CommonResource.Back
                </a>
                <a href="javascript:void(0);" class="btn btn-icon btn-circle btn-sm btn-light-primary mr-1" data-card-tool="toggle">
                    <i class="ki ki-arrow-down icon-nm"></i>
                </a>
            </div>*@
    </div><div class="card-body">


        <div class="form-group row">
            <div class="col-lg-12" style="padding-top:15px;">
                @*<label>@PhysicalExaminationReportResource.ReportOfThePhysicalExaminationCommittee:</label>*@
                @if (viewMode)
                {
                    @Html.TextAreaFor(m => m.TherapeuticPlan, new { @class = "form-control", @rows = "10", @placeholder = TherapeuticPlanResource.TherapeuticPlan, @id = "TherapeuticPlan", @readonly = "readonly" })
                }
                else
                {
                    <button type="button" id="TherapeuticPlanRecorder" class="recordButtonClass recbutton-sm" style="@(Model.TherapeuticPlanVoiceAttachPath!=null?"display:none":"")"></button>
                    @Html.TextAreaFor(m => m.TherapeuticPlan, new { @class = "form-control", @rows = "10", @placeholder = TherapeuticPlanResource.TherapeuticPlan, @id = "TherapeuticPlan" })
                    @Html.ValidationMessageFor(x => x.TherapeuticPlan)
                    <span class="form-text text-muted">@TherapeuticPlanResource.TherapeuticPlanInfoSpan</span>
                }

                @if (Model.TherapeuticPlanVoiceAttachPath != null)
                {
                    <div class="row">
                        <div class="col-md-4">

                            <ul id="TherapeuticPlanVoicerecord" class="recordsection">
                                <li>
                                    <audio controls="" src="@(Model.TherapeuticPlanVoiceAttachPath)"></audio>
                                </li>
                            </ul>
                        </div>
                        @if (!viewMode)
                        {
                            <div class="col-md-8" style="padding:20px">
                                <span class="fa fa-trash recycler" id="TherapeuticPlanTrash" style="font-size:20px"></span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="row">
                        <div class="col-md-4">
                            <ul id="TherapeuticPlanVoicerecord" class="recordsection">
                            </ul>
                        </div>
                        <div class="col-md-8" style="padding:20px">
                            <span class="fa fa-trash recycler" id="TherapeuticPlanTrash" style="font-size:20px;display:none"></span>
                        </div>
                    </div>
                }
            </div>
        </div>



        <br />
        <div class="row">
            <div class="col-md-12">
                <div class="box-body @customeClass" role="tabpanel">
                    <label>@TeleMentalHealthResource.MidicationName:</label>
                    @(Html.Kendo().Grid<Medication_MHTherapeuticPlanDTO>
    (Model.Medications)
    .Name("Medications")
    .Sortable()
    .Columns(columns =>
    {

        columns.Bound(c => c.Id).ClientTemplate("#=getRowIndex(uid)#").Title("#").Sortable(false).Width(50);
        if (viewMode)
        {
            columns.Bound(c => c.MedicationName).Filterable(false).Title(TeleMentalHealthResource.MidicationName).Width(200);
        }
        else
        {
            columns.Bound(c => c.MedicationId).Filterable(false)
                                         .EditorTemplateName("MedicationDDL")
                                         .ClientTemplate("#= MedicationName#" +
                                        "<input type='hidden' name='Medications[#= getIndex(data)#].MedicationName' value='#= MedicationName #' />" +
                                        "<input type='hidden' name='Medications[#= getIndex(data)#].MedicationId' value='#=MedicationId #' />")
                                         .Title(TeleMentalHealthResource.MidicationName).Width(200);
        }


        columns.Bound(p => p.Descreption).ClientTemplate("<div style='background-color:rgba(239, 239, 239, .5); padding:10px; width:100%;  ' > #= Descreption # </div>" +
        "<input type='hidden' name='Medications[#= getIndex(data)#].Descreption' value='#= Descreption #' />")
        .Title(TeleMentalHealthResource.Descreption).Width(200);

        columns.Command(command => {
            if (!viewMode)
            {
                command.Destroy().Text(CommonResource.Delete);
            }
        });
    })
    .ToolBar(toolBar => {
        if (!viewMode)
        {
            toolBar.Create().Text(CommonResource.AddNew);
        }

    })
    .Scrollable(s => s.Enabled(true).Height("600px"))

    .HtmlAttributes(new { style = "height:600px", @id = "Medications" })
    .Editable(editable => editable.Mode(GridEditMode.InCell).CreateAt(GridInsertRowPosition.Bottom).DisplayDeleteConfirmation(false))
    .Navigatable()
    .DataSource(dataSource => dataSource
    .Ajax()
    .Model(model =>
    {
        model.Id(p => p.Id);
        model.Field(x => x.Id).Editable(false);
        model.Field(x => x.TelMHTherapeuticPlanId);
        if(viewMode)
        {
            model.Field(x => x.MedicationId).Editable(false);
            model.Field(x => x.MedicationName).Editable(false);
            model.Field(x => x.Descreption).Editable(false);
        }
    })
   .Events(e => e.Change("onMedicationGridChange"))
    .ServerOperation(false)

    .Events(events => events.Error("function(args){KendoGrid_ErrorHandler(args,'Medications');}"))
    ).Events(x => x.Edit("onEditMedication"))
            )





                </div>
            </div>
        </div>
        <br />
        <div class="form-group row">
            <div class="col-lg-12" style="padding-top:15px">
                <label>@TherapeuticPlanResource.Notes:</label>

                @if (viewMode)
                {
                    @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", @rows = "10", @placeholder = TherapeuticPlanResource.Notes, @id = "Notes", @readonly = "readonly" })
                }
                else
                {
                    @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", @rows = "10", @placeholder = TherapeuticPlanResource.Notes, @id = "Notes" })
                    @Html.ValidationMessageFor(x => x.Notes)
                    <span class="form-text text-muted">@TherapeuticPlanResource.NotesInfoSpan</span>
                }
                <div>
                    <div class="k-widget k-tooltip-validation k-invalid-msg field-validation-error" style="margin: 0.5em; display: none; " id="errorMessage">
                        <span class="fa fa-times-circle" style="margin-top:5px; color:#d9534f;"> </span><label id="errorMsgTxt"></label>
                    </div>
                    @if (!viewMode)
                    {
                        @(Html.Kendo().Upload().Messages(m => m.Select(CommonResource.SelectFile))
                .Name("MHTherapeuticPlanNotesFiles")
                .ShowFileList(true)
                .Multiple(false)
                .Async(a => a
                .Save("AddMHTherapeuticPlanNotesFile", "Attachment", new { fileGuid = Guid.NewGuid() })
                .AutoUpload(true)
                ).Events(c => c
                .Select("onSelectFile")
                    .Success("onSuccessUploadMHTherapeuticPlanNotesFile")))
                    }



                    <br />
                    @if (Model.NotesAttachmentId.HasValue)
                    {
                        @Model.NotesFilename <a href='@Url.Action("Download", "Attachment")?attachmentId=@HashIdsManager.Encrypt(Model.NotesAttachmentId.Value)'><i class='fa fa-download' style='color:black'></i></a>
                    }

                </div>
            </div>


        </div>
        @if (!viewMode)
        {
            <div class="row">
                <div class="col-lg-12">
                    <button type="button" id="save" class="btn btn-primary">@CommonResource.Save</button>
                    <button type="button" id="cancel" class="btn btn-default">@CommonResource.Cancel</button>
                </div>
            </div>
        }


        <!--<a href="#" class="btn btn-icon btn-warning btn-circle btn-lg" style="position:fixed; bottom:60px; right:115px;">
        <span class="svg-icon">-->
        <!--begin::Svg Icon | path:assets/media/svg/icons/Design/PenAndRuller.svg-->
        <!--<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
            <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                <rect x="0" y="0" width="24" height="24"></rect>
                <path d="M3,16 L5,16 C5.55228475,16 6,15.5522847 6,15 C6,14.4477153 5.55228475,14 5,14 L3,14 L3,12 L5,12 C5.55228475,12 6,11.5522847 6,11 C6,10.4477153 5.55228475,10 5,10 L3,10 L3,8 L5,8 C5.55228475,8 6,7.55228475 6,7 C6,6.44771525 5.55228475,6 5,6 L3,6 L3,4 C3,3.44771525 3.44771525,3 4,3 L10,3 C10.5522847,3 11,3.44771525 11,4 L11,19 C11,19.5522847 10.5522847,20 10,20 L4,20 C3.44771525,20 3,19.5522847 3,19 L3,16 Z" fill="#000000" opacity="0.3"></path>
                <path d="M16,3 L19,3 C20.1045695,3 21,3.8954305 21,5 L21,15.2485298 C21,15.7329761 20.8241635,16.200956 20.5051534,16.565539 L17.8762883,19.5699562 C17.6944473,19.7777745 17.378566,19.7988332 17.1707477,19.6169922 C17.1540423,19.602375 17.1383289,19.5866616 17.1237117,19.5699562 L14.4948466,16.565539 C14.1758365,16.200956 14,15.7329761 14,15.2485298 L14,5 C14,3.8954305 14.8954305,3 16,3 Z" fill="#000000"></path>
            </g>
        </svg>-->
        <!--end::Svg Icon-->
        <!--</span>
        </a>-->

    </div>




}



<!--end::Form-->




<script src="~/Scripts/jquery.validate-vsdoc.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<script>

    var isRecordPressed = false;
    var isStop = false;
    var BufferVoiceMessage;
    var BufferVoiceMessageForRemark;
    var IsModalClosePressed = false;
    var PressedRecordButton = "";
    var MyFileTherapeuticPlan;

    $("#TelMHTherapeuticPlanFormId").on("submit", function (e) {

            e.preventDefault();
        var formData = new FormData();
        formData.append("TherapeuticPlanVoice", MyFileTherapeuticPlan);

        var formdataSerialize = $(this).serializeArray();
        for (var i = 0; i < formdataSerialize.length; i++) {

            formData.append(formdataSerialize[i].name, formdataSerialize[i].value);
        }


            $.ajax({
                url: this.action,
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Success) {
                        ShowSuccessfllyMsg(data.Message);
                        $('#main-content').load('@Url.Action("GetTelMHTherapeuticPlan", "TeleMentalHealth", new { planId="", mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) })', function () {});
                        $('#sticky-menu').load('@Url.Action("GetSickyMenu", "TeleMentalHealth", new { mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) })', function () {
                            onmenueload();
                            $("#TherapeuticPlanBtn").addClass("active");
                        });
                        refresh();
                    } else {
                        onJSError(data.Message);
                        $("#save").removeAttr("disabled");
                    }
                }
            });




           // $("#ManifestItemFormId").submit();
    });

    $("#save").on("click", function (e) {
        debugger;
        var grid = $("#Medications").data("kendoGrid");
        if (grid.dataSource.data().length == 0) {
            //onJSError();
          //  return;
        }

        var medications = grid.dataSource.data();
        for (var i = 0; i < medications.length; i++) {
            if (medications[i].MedicationId == 0) {
                onJSError("Please Select Medication...");
                return;
            }

        }
        $('#TelMHTherapeuticPlanFormId').validate();
        if ($("#TelMHTherapeuticPlanFormId").valid()) {



            $("#save").attr("disabled", "disabled");



            $("#TelMHTherapeuticPlanFormId").submit();
        }
    });

    $('#RecordModal').on('hidden.bs.modal', function () {
        var recordingsList = document.getElementById("recordingsList");
        recordingsList.innerHTML = "";
        $(".recordButtonClass").removeClass("Rec");
        $(".recordButtonClass").addClass("notRec");
        $(".recordReplyButtonClass").removeClass("Rec");
        $(".recordReplyButtonClass").addClass("notRec");
        //  BufferVoiceMessage = null;
        if (IsModalClosePressed) {
            stopRecordingForClose();
        }
        var seconds = $("#secondsrecord");
        var minutes = $("#minutesrecord");

        seconds.text("00");
        minutes.text("00");
    });
    $('#RecordModal').on('shown.bs.modal', function () {
        IsModalClosePressed = false;
        var recordingsList = document.getElementById("recordingsList");
        recordingsList.innerHTML = "";
        BufferVoiceMessage = null;
        IsStop = false;
        var minuts = $("#secondsrecord");
        var seconds = $("#secondsrecord");
        var minutes = $("#minutesrecord");

        //   seconds.text("00");
        // minutes.text("00");
    });

    $("#TherapeuticPlanRecorder").on("click", function () {
        PressedRecordButton = "TherapeuticPlans";
    });
    $('#TherapeuticPlanTrash').on("click", function () {

        $('#TherapeuticPlanRecorder').show();
        $('#TherapeuticPlanVoicerecord').html('');
        $('#TherapeuticPlanTrash').hide();
        MyFileTherapeuticPlan = null;
        $('#IsTherapeuticPlanVoiceDeleted').val(true);
    });


       $("#cancel").on("click", function (e) {
       $('#main-content').load('@Url.Action("GetTelMHTherapeuticPlan", "TeleMentalHealth", new { planId = "", mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) })', function () { });
    });

    $("#AddFollowUpBtn").on("click", function () {
         $('#main-content').load('@Url.Action("GetTelMHTherapeuticPlanForAdd", "TeleMentalHealth", new { mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) })', function () {});

    });
    function getRowIndex(id) {
        debugger;


        var grid = $('#Medications').data('kendoGrid');
        var Medications = grid.dataSource.view();


        for (var i = 0; i < Medications.length; i++) {
            if (Medications[i].uid == id) {
                return i + 1;
                break;
            }
        }
    }

    function GetPreviousMedicationId() {
        var textInput = $("[name='MedicationId']").data("kendoDropDownList").filterInput.val()
        var rowInEditMode = $("#Medications").find("td.k-edit-cell").parent('tr');
        var itemBeingEdited = $("#Medications").data("kendoGrid").dataSource.getByUid(rowInEditMode.data("uid"));

        var medicationId = itemBeingEdited.MedicationId;

        return { text: textInput, previousId: medicationId };
    }
    function getIndex(dataBill) {
        var data = $("#Medications").data("kendoGrid").dataSource.data();
        return data.indexOf(dataBill);
    }


</script>
<script src="~/assets/js/WebAudioRecorder.min.js" type="text/javascript"></script>
<script src="~/assets/js/app.js" type="text/javascript"></script>