@using BoulevardManagement.DTO;
@using BoulevardManagement.WebApplication.Resources;
@using TripleA.Utilities.HashidsNet;
@model TelMHTherapeuticPlanDTO


<script type="text/javascript" src="~/Scripts/FileUpload.js"></script>
<style>
    .k-icon.k-i-add {
        color: #fff !important;
    }
</style>

