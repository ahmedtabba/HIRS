
@using BoulevardManagement.WebApplication.Resources;

@model  int
@(Html.Kendo().DropDownListFor(x=>x)@*.Name("TelMHDiagnosisCategoryName")*@
                      .DataTextField("Name")
                      .DataValueField("Id")
                      .OptionLabel(CommonResource.Select)
                      .DataSource(source =>
                      {
                          source.Read(read =>
                          {

                              read.Action("GetDiagnosisCategorys", "TeleMentalHealth");
                          }).Events(e => e.Error("KendoDDL_ErrorHandler"))
                              .ServerFiltering(true);
                      }).Filter("contains")
                      .Value(Model.ToString())
                      .HtmlAttributes(new { required = true, validationmessage = "required field",@id= "TelMHDiagnosisCategoryId" })
// .Events(e => e/*.Select("onSelectedItem")*//*.Change("DiagnosisCategoryDDLChange")*/)

)
