@using BoulevardManagement.WebApplication.Models;
@using BoulevardManagement.WebApplication.Resources;
@using TripleA.Utilities.HashidsNet;
@using BoulevardManagement.DTO;

@model MonitoringTheVitalSignsVM

@{
    var customeClass = "";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }

    var viewMode = !User.IsInRole(RoleConsistent.TeleMentalHealth.EditMonitoringTheVitalSigns) || Model.CaseStatus == CaseStatus.Closed;
}



<div class="card-header">
    <div class="card-title">
        <h3 class="card-label">

            @MonitoringTheVitalSignsResource.MonitoringTheVitalSigns


        </h3>
    </div>
</div>





<div class="card-body " kt-hidden-height="471" style="">
    <div class="row" style="margin-bottom:20px;">
        @if (!viewMode)
        {
            <div class="col-lg-12">
                <a href="javascript:void(0);" onclick="setTime()" id="test" class="btn btn-primary" data-toggle="modal" data-target="#AddVitalSignModal">@MonitoringTheVitalSignsResource.AddVitalSign</a>

            </div>
        }
    </div>
    <div class="row">
        <div class="col-lg-12 @customeClass">
            @(Html.KendoGrid<BoulevardManagement.DTO.TelMHVitalSignDTO>().Name("TelMHVitalSignGrid")
.Columns(columns =>
{
//Text Field Template
// columns.Bound(c => c.TextFiledName).Title("Title").Width(200);

//Bool Field Template
//columns.Bound(c => c.BoolFieldName).Title("Title?").ClientTemplate("#if (BoolFieldName) {# " + "Yes" + "#}else{#" + "No" + "#}#").Width(120);

//Date Field Template
//columns.Bound(c => c.DateFieldName).Title("Title").Filterable(c => c.Cell(x => x.Template("datePicker")).Operators(x => x.ForDate(d => d.IsEqualTo("equal")))).Width(150).Format(@"{0:dd/MM/yyyy}");
if (this.User.IsInRoles(RoleConsistent.TeleMentalHealth.Edit)|| this.User.IsInRoles(RoleConsistent.TeleMentalHealth.Delete))
    columns.Bound(c => c.BloodPressure).ClientTemplate("#=BloodPressureLang#").Title(MonitoringTheVitalSignsResource.BloodPressure).Width(90);
//columns.Bound(c => c.MapBloodPressure).Title(MonitoringTheVitalSignsResource.Map).Width(90);

columns.Bound(c => c.Temperature).Title(MonitoringTheVitalSignsResource.Temperature).Width(90);
columns.Bound(c => c.Pulse).Title(MonitoringTheVitalSignsResource.Pulse).Width(90);
columns.Bound(c => c.Oxygenation).Title(MonitoringTheVitalSignsResource.Oxygenation).Width(90);
columns.Bound(c => c.TimeOfMeasurement).Title(MonitoringTheVitalSignsResource.Time).Filterable(c => c.Cell(x => x.Template("datePicker")).Operators(x => x.ForDate(d => d.IsEqualTo("equal")))).Width(150).Format(@"{0:dd/MM/yyyy hh:mm:tt}");

columns.Bound(c => c.Name).Title(MonitoringTheVitalSignsResource.Name).Width(90);
if (!viewMode && (User.IsInRole(RoleConsistent.TeleMentalHealth.Delete)|| User.IsInRole(RoleConsistent.TeleMentalHealth.Edit)) )
    columns.Template(@<text></text>).HeaderHtmlAttributes(new { @style = "padding-bottom:11px;" }).ClientTemplate("#=templateOptions(EncrptedId,this)#").Title(CommonResource.Oprions).Width(50);
   columns.Command(command => { command.Custom("VitalSignEdit").Text("<span class='navi-icon flaticon2-contract'></span> Edit ").Click("EditRowTelMHVitalSignGrid"); }).Hidden();
    if (!viewMode)
        columns.Command(command => { command.Custom("TeleMentalHealthDestroy").Text("<span class='k-icon k-i-close'></span> Delete ").Click("DeleteRowTelMHVitalSignGrid"); }).Hidden();

})
            .HtmlAttributes(new { style = "height:1000px", @id = "TelMHVitalSignGrid" })
            .ToolBar(toolbar => { toolbar.Excel().HtmlAttributes(new { style = "display:none" }); toolbar.Pdf().HtmlAttributes(new { style = "display:none" }); })
            .ColumnMenu(c => c.Columns(true))
            .Pdf(exp => exp.FileName("TelMHVitalSign.pdf").ProxyURL(Url.Action("Export_Save", "Base")).AllPages().AvoidLinks().PaperSize("A4").Scale(0.8).Margin("2cm", "1cm", "1cm", "1cm").Landscape().RepeatHeaders().TemplateId("page-template"))
            .Excel(exp => exp.FileName("TelMHVitalSign.xlsx").ProxyURL(Url.Action("Export_Save", "Base")).AllPages(true))
            .DataSource(dataSource => dataSource
            .Ajax()
            .Model(model => model.Id(c => c.Id))
.Destroy(action => action.Action("Delete_VitalSign", "TeleMentalHealth"))
.Read(read => read.Action("Read_VitalSign", "TeleMentalHealth", new { mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) }))
            .Events(events => events.Error("function(e){KendoGrid_ErrorHandler(e,'TelMHVitalSignGrid');}").RequestEnd("myOnReqEnd"))
            )
            .ColumnMenu(c => c.Columns(false).Filterable(false))
                                )
        </div>
    </div>
</div>





@Html.Partial("Modals/ConfirmModal", new BoulevardManagement.WebApplication.Models.DeleteConfirmModal())
@Html.Partial("_AddVitalSignModel")





<script>
    $('#vital-sign-content').load('@Url.Action("GetVitalSignForm", "TeleMentalHealth", new { vitalSignId = "", mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) })', function () {
        @*var datetimepicker = $("#datetimepicker").data("kendoDateTimePicker");
        datetimepicker.value("@DateTime.Now.Day" + "/" + "@DateTime.Now.Month" + "/" + "@DateTime.Now.Year" + " " + "@DateTime.Now.ToString("hh:mm tt")");*@
    });

    function setTime() {
        @*
        var datetimepicker = $("#datetimepicker").data("kendoDateTimePicker");
        datetimepicker.value("@DateTime.Now.Day" + "/" + "@DateTime.Now.Month" + "/" + "@DateTime.Now.Year" + " " + "@DateTime.Now.ToString("hh:mm tt")");*@
    }






    function templateOptions(id, ob) {
        

          var EditUrl = "";
         var DeleteLi = "";
           if ('@this.User.IsInRole(RoleConsistent.TeleMentalHealth.Delete)'=='True') {
               DeleteLi = "<li class='navi-item'>" + "<a onClick=" + "\"DeleteRowTelMHVitalSignGrid(" + ob + ")\"" +" href='#' class='navi-link  k-button-icontext k-grid-TeleMentalHealthDestroy'><i class='navi-icon flaticon2-trash'></i><span class='navi-text'>@CommonResource.Delete</span></a></li>";
               EditLi = "<li class='navi-item'>" + "<a onClick=" + "\"EditRowTelMHVitalSignGrid(" + ob + ")\"" +" href='#' class='navi-link  k-button-icontext k-grid-VitalSignEdit'><i class='navi-icon flaticon2-contract'></i><span class='navi-text'>@CommonResource.Edit</span></a></li>";

           }
           @*if ('@this.User.IsInRole(RoleConsistent.TeleMentalHealth.Edit)'=='True') {
               EditUrl = '@Url.RouteUrl("Default", new { controller = "TeleMentalHealth", action = "Edit" })' + "?MentalHealthId=" + id;
          }*@

        var result = `<div class=" ml-2"  >


<a href="#" class="btn btn-clean btn-hover-light-primary btn-sm btn-icon" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
															<span class="svg-icon svg-icon-lg">
																<!--begin::Svg Icon | path:assets/media/svg/icons/Text/Dots.svg-->
																<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
											<g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
												<rect x="0" y="0" width="24" height="24" />
												<path d="M7,3 L17,3 C19.209139,3 21,4.790861 21,7 C21,9.209139 19.209139,11 17,11 L7,11 C4.790861,11 3,9.209139 3,7 C3,4.790861 4.790861,3 7,3 Z M7,9 C8.1045695,9 9,8.1045695 9,7 C9,5.8954305 8.1045695,5 7,5 C5.8954305,5 5,5.8954305 5,7 C5,8.1045695 5.8954305,9 7,9 Z" fill="#000000" />
												<path d="M7,13 L17,13 C19.209139,13 21,14.790861 21,17 C21,19.209139 19.209139,21 17,21 L7,21 C4.790861,21 3,19.209139 3,17 C3,14.790861 4.790861,13 7,13 Z M17,19 C18.1045695,19 19,18.1045695 19,17 C19,15.8954305 18.1045695,15 17,15 C15.8954305,15 15,15.8954305 15,17 C15,18.1045695 15.8954305,19 17,19 Z" fill="#000000" opacity="0.3" />
											</g>
										</svg>
																<!--end::Svg Icon-->
															</span>
														</a>


<div class="dropdown-menu dropdown-menu-sm p-0 m-0 dropdown-menu-right">
											<ul class="navi py-5">
`;
        if (EditLi != "") {
            result = result + EditLi;
        }
        if (DeleteLi != "") {
            result = result + DeleteLi;
        }

        result = result +
            "</ul></div></div>";

        return result;
    }

</script>
