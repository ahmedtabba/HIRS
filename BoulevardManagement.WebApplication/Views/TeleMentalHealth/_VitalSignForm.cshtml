@using BoulevardManagement.DTO;
@using TripleA.Utilities.HashidsNet;
@using BoulevardManagement.WebApplication.Resources;
@model TelMHVitalSignDTO


<style>
    .custom-style.k-datetimepicker .k-picker-wrap .k-icon {
        margin-top: 10px !important;
    }
</style>


@using (Html.BeginForm("UpdateVitalSign", "TeleMentalHealth", FormMethod.Post, new { @id = "TelMHVitalSignFormId" }))
{
    <div class="modal-body">

        @Html.AntiForgeryToken()
        @Html.HiddenFor(x => x.Id)
        @Html.HiddenFor(x => x.TeleMentalHealthId)
        <div class="row">
            <div class="form-group col-lg-4">
                <label>@VitalSignFormResource.BloodPressure:</label>
                <div>
                    @Html.EditorFor(m => m.BloodPressureFirstPart, new { htmlAttributes = new { @class = "form-control", @id = "BloodPressureFirstPart", Style = "width:30%; display:inline-block;", @type = "number", @min = "0" } })
                    @if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
                    {
                          <span>
                              \
                          </span>
                    }
                    else
                    {
                <span>
                    /
                </span>
                    }
                    @Html.EditorFor(m => m.BloodPressureSecondPart, new { htmlAttributes = new { @class = "form-control", @id = "BloodPressureSecondPart", Style = "width:30%; display:inline-block;", @type = "number", @min = "0" } })
                    <div>
                        @Html.ValidationMessageFor(x => x.BloodPressureFirstPart)
                        @Html.ValidationMessageFor(x => x.BloodPressureSecondPart)
                    </div>
                </div>
                <span class="form-text text-muted">@VitalSignFormResource.BloodPressureInfoSpan</span>
            </div>
            @*<div class="form-group col-lg-4">
            <label>@VitalSignFormResource.Map:</label>
            @Html.EditorFor(m => m.MapBloodPressure, new { htmlAttributes = new { @class = "form-control num-box", @placeholder = VitalSignFormResource.Map, @id = "MapBloodPressure", @type = "number", @min = "0" ,@readonly = "readonly" } })
            @Html.ValidationMessageFor(x => x.MapBloodPressure)
            <span class="form-text text-muted">@VitalSignFormResource.Map</span>
        </div>*@
            <div class="form-group col-lg-4">
                <label>@VitalSignFormResource.Temperature:</label>
                @Html.EditorFor(m => m.Temperature, new { htmlAttributes = new { @class = "form-control", @placeholder = @VitalSignFormResource.Temperature, @id = "Temperature" } })
                @Html.ValidationMessageFor(x => x.Temperature)
                <span class="form-text text-muted">@VitalSignFormResource.TemperatureInfoSpan</span>
            </div>

            <div class="form-group col-lg-4">
                <label>@VitalSignFormResource.Pulse:</label>
                @Html.EditorFor(m => m.Pulse, new { htmlAttributes = new { @class = "form-control", @placeholder = @VitalSignFormResource.Pulse, @id = "Pulse" } })
                @Html.ValidationMessageFor(x => x.Pulse)
                <span class="form-text text-muted">@VitalSignFormResource.PulseInfoSpan</span>
            </div>
        </div>

        <div class="row">
         
            <div class="form-group col-lg-4">
                <label>@VitalSignFormResource.Oxygenation:</label>
                @Html.EditorFor(m => m.Oxygenation, new { htmlAttributes = new { @class = "form-control", @placeholder = @VitalSignFormResource.Oxygenation, @id = "Oxygenation" } })
                @Html.ValidationMessageFor(x => x.Oxygenation)
                <span class="form-text text-muted">@VitalSignFormResource.OxygenationInfoSpan</span>
            </div>

            <div class="form-group col-lg-4">



                <label>@VitalSignFormResource.Time:</label>
                @(Html.Kendo().DateTimePicker().Format("dd/MM/yyyy hh:mm tt").TimeFormat("hh:mm tt")

                                  .Name("datetime").Value(Model.TimeOfMeasurement).Max(DateTime.Now)
                               .HtmlAttributes(new { @type = "text", @class = "form-control custom-style", title = "datepicker", @style = "width:100%" ,@id= "datetime", onkeydown = "javascript:return false;" })

                            )
                <input hidden name="TimeOfMeasurement" id="TimeOfMeasurement" value="@Model.TimeOfMeasurement" />
                @Html.ValidationMessageFor(x => x.TimeOfMeasurement)
                <span class="form-text text-muted">@VitalSignFormResource.TimeInfoSpan</span>
            </div>

            <div class="form-group col-lg-4">
                <label>@VitalSignFormResource.Name:</label>
                @Html.EditorFor(m => m.Name, new { htmlAttributes = new { @class = "form-control", @placeholder = @VitalSignFormResource.Name, @id = "Name" } })
                @Html.ValidationMessageFor(x => x.Name)
                <span class="form-text text-muted">@VitalSignFormResource.NameInfoSpan</span>
            </div>
        </div>


    </div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">@CommonResource.Cancel</button>
        <button type="button" id="save" class="btn btn-primary">@CommonResource.Save</button>
    </div>
}



<script src="~/Scripts/jquery.validate-vsdoc.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<script>
    $("#TelMHVitalSignFormId").on("submit", function (e) {
        
    e.preventDefault();
        $("#TimeOfMeasurement").val($('#datetime').val());
            $.ajax({
    url: this.action,
                type: this.method,
                data: $(this).serialize(),
                success: function (data) {
            if (data.Success) {
                ShowSuccessfllyMsg(data.Message);
