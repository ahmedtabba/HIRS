        $("#save").on("click", function (e) {
            
            $('#TelMHVitalSignFormId').validate();

            if ($("#TelMHVitalSignFormId").valid()) {



            $("#save").attr("disabled", "disabled");



                $("#TelMHVitalSignFormId").submit();
