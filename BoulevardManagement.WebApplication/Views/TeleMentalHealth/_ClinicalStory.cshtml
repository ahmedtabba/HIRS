        $('#CaseSummaryTrash').hide();
        MyFileCaseSummary = null;
        $('#IsCaseSummaryVoiceDeleted').val(true);
    });



    function GetCurrentDiagnosisCategoryId() {
        debugger;
        var diagnosisCategoryId = $("#TelMHDiagnosisCategoryId").data("kendoDropDownList").value();
        var text = $("[name='TelMHDiagnosisCategoryId']").data("kendoDropDownList").filterInput.val();
        return { text: text, currentId: diagnosisCategoryId }
    }



    function myOnReqEnd(e) {

        if (e.response.Data.length == 0)
            return;
        if (e.type === "destroy") {
            var details = ``;
            onRequestEnd(e, details);
        }
    }


    function GetClinicalStoryId() {
        var text = $("[name='TelMHDiagnosisCategoryId']").data("kendoDropDownList").filterInput.val();
        return { text: text, clinicalStoryId: '@Model.Id' };
    }



    function GetDataForMLSubDiagnosis() {
        var textInput = $("[name='TelMHMostLikelySubDiagnosesIds']").data("kendoMultiSelect")._prev;
       // var textInput = "";
        var rowInEditMode = $("#MostLikelyDiagnosis").find("tr.k-grid-edit-row");
        var itemBeingEdited = $("#MostLikelyDiagnosis").data("kendoGrid").dataSource.getByUid(rowInEditMode.data("uid"));

        var diagnosisCategoryId = itemBeingEdited.TelMHDiagnosisCategoryId;
        

        return {
            text: textInput, diagnosisCategoryId: diagnosisCategoryId};
    }



    function DiagnosisCategoryFMLDDDLChange() {
        debugger;
        var dropdownlist = $("#TelMHMostLikelySubDiagnosesIds").data("kendoMultiSelect");
        dropdownlist.dataSource.read();
        dropdownlist.refresh();
    }

