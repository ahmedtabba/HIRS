        $('#RemarksVoiceRecorder').show();
        $('#Remarkrecord').html('');
        $('#RemarkrecordTrash').hide();
        myFileRemarks = null;
        $('#IsRemarksVoiceDeleted').val(true);
    });
    $('#CurrentComplaintTrash').on("click", function () {

        $('#CurrentComplaintRecorder').show();
        $('#CurrentComplaintVoicerecord').html('');
        $('#CurrentComplaintTrash').hide();
        myFileCurrentComplaint = null;
