    $("#CurrentComplaintRecorder").on("click", function () {
        PressedRecordButton = "CurrentComplaint";
    });
    $("#RiskAssessmentRecorder").on("click", function () {
        PressedRecordButton = "RiskAssessment";
    });
    $("#CaseSummaryRecorder").on("click", function () {
        PressedRecordButton = "CaseSummary";
    });
