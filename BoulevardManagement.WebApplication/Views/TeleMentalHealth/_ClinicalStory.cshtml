<script>
    var isRecordPressed = false;
    var isStop = false;
    var BufferVoiceMessage;
    var BufferVoiceMessageForRemark;
    var IsModalClosePressed = false;
    var myFileRemarks;
    var myFileCurrentComplaint;
    var MyFileRiskAssessment;
    var MyFileCaseSummary;

    var PressedRecordButton="";

    //var myblob;
    $("#TelMHClinicalStoryFormId").on("submit", function (e) {
        debugger;
            e.preventDefault();
        var formData = new FormData();
        formData.append("remarksVoice", myFileRemarks);
        formData.append("CurrentComplaintVoice", myFileCurrentComplaint);
        formData.append("RiskAssessmentVoice", MyFileRiskAssessment);
        formData.append("CaseSummaryVoice", MyFileCaseSummary);

        let container = new DataTransfer();
        var formdataSerialize = $(this).serializeArray();
        for (var i = 0; i < formdataSerialize.length; i++) {

            formData.append(formdataSerialize[i].name, formdataSerialize[i].value);
        }


       // console.log(formdata11);
            $.ajax({
                url: "@(Url.Action("UpdateClinicalStory", "TeleMentalHealth"))",
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Success) {
                        ShowSuccessfllyMsg(data.Message);
                        $('#main-content').load('@Url.Action("GetClinicalStory", "TeleMentalHealth", new { mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) })', function () {});
                        $('#sticky-menu').load('@Url.Action("GetSickyMenu", "TeleMentalHealth", new { mentalHealthId = HashIdsManager.Encrypt(Model.TeleMentalHealthId) })', function () {
                            onmenueload();
                            $("#ClinicalStoryBtn").addClass("active");
                        });
                    } else {
                        onJSError(data.Message);
                        $("#save").removeAttr("disabled");
                    }
                }
            });




           // $("#ManifestItemFormId").submit();
    });

        $("#save").on("click", function (e) {

          //  $('#voice').val(formData);
        $('#TelMHClinicalStoryFormId').validate();
        if ($("#TelMHClinicalStoryFormId").valid()) {

            var DiagnosisItems = $("#Diagnosis").data("kendoGrid")._data;

            for (var i = 0; i < DiagnosisItems.length; i++) {
                if (DiagnosisItems[i].TelMHDiagnosisCategoryId == 0 || DiagnosisItems[i].TelMHDiagnosisSubCategoryId == 0) {
                    onJSError("Diagnosis not valid");
                    return;
                }
            }

            $("#save").attr("disabled", "disabled");



            $("#TelMHClinicalStoryFormId").submit();
        }
        });


    $('#RecordModal').on('hidden.bs.modal', function () {
        var recordingsList = document.getElementById("recordingsList");
        recordingsList.innerHTML = "";
        $(".recordButtonClass").removeClass("Rec");
        $(".recordButtonClass").addClass("notRec");
        $(".recordReplyButtonClass").removeClass("Rec");
        $(".recordReplyButtonClass").addClass("notRec");
      //  BufferVoiceMessage = null;
        if (IsModalClosePressed) {
            stopRecordingForClose();
        }
        var seconds = $("#secondsrecord");
        var minutes = $("#minutesrecord");

        seconds.text("00");
        minutes.text("00");
    });
    $('#RecordModal').on('shown.bs.modal', function () {
        IsModalClosePressed = false;
        var recordingsList = document.getElementById("recordingsList");
        recordingsList.innerHTML = "";
        BufferVoiceMessage = null;
        IsStop = false;
        var minuts = $("#secondsrecord");
        var seconds = $("#secondsrecord");
        var minutes = $("#minutesrecord");

        //   seconds.text("00");
        // minutes.text("00");
    });

