@using BoulevardManagement.DTO
@using BoulevardManagement.WebApplication.Resources;
@using BoulevardManagement.DTO.Resources;


@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}


@model BoulevardManagement.DTO.ProjectDTO

@if (Model.Id == 0)
{
    ViewBag.Title = ProjectViewResource.CreateTitle;
}
else
{
    ViewBag.Title = ProjectViewResource.EditTitle;
}

@using (Html.BeginForm("Edit", "Project", FormMethod.Post, new { @class = "", role = "form", id = "ProjectId" }))
{

    @Html.AntiForgeryToken()

    <div class="box box-primary">
        <div class="box-body" role="tabpanel">
            <div class="row">
                <div class="col-sm-6">
                    <div class="form-group required">
                        @Html.Label(ProjectViewResource.Code, new { @class = "form-label", pattern = ".{2,2}" })
                        @Html.EditorFor(m => m.Code, new { htmlAttributes = new { @class = "form-control", @placeholder = ProjectViewResource.Code, @id = "Code", @type = "number" } })
                        @Html.ValidationMessageFor(x => x.Code)
                    </div>
                    <div class="form-group  required">
                        @Html.Label(ProjectViewResource.Name, new { @class = "form-label" })
                        @Html.EditorFor(m => m.Name, new { htmlAttributes = new { @class = "form-control", @placeholder = ProjectViewResource.Name, @id = "Name" } })
                        @Html.ValidationMessageFor(x => x.Name)

                    </div>
                    <div class="form-group  ">
                        @Html.Label(ProjectViewResource.Description, new { @class = "form-label" })
                        @Html.EditorFor(m => m.Description, new { htmlAttributes = new { @class = "form-control", @placeholder = ProjectViewResource.Description } })
                    </div>


                </div>

            </div>

            <div class="row">
                <div class="col-lg-12">
                    <div class="btn-toolbar well">
                        @if (Model.Id == 0)
                        {
                            <button type="submit" class="btn btn-primary pull-right">
                                <i class="fa fa-user-plus" aria-hidden="true"></i> @ProjectViewResource.CreateBtn
                            </button>
                        }
                        else
                        {

                            @Html.HiddenFor(model => model.Id)
                            <button type="submit" class="btn btn-primary pull-right">
                                <i class="fa fa-floppy-o" aria-hidden="true"></i> @ProjectViewResource.SaveBtn
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

