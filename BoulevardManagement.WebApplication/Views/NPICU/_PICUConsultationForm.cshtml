        <h6>
            @PICUConsultationFormResource.PhysicalExamination
        </h6>
        <hr />
        <div class="row form-group" style="margin-top:20px;">
            <div class="col-lg-12">
                <div class="required @customeClass">
                    <div class="k-widget k-tooltip-validation k-invalid-msg field-validation-error" style="margin: 0.5em; display: none; " id="PhysicalExaminationfileserrorMessage">
                        <span class="fa fa-times-circle" style="margin-top:5px; color:#d9534f;"> </span><label id="PhysicalExaminationfileserrorMsgTxt"></label>
                    </div>
                    @if (!viewMode)
                    {
                        @(Html.Kendo().Upload().Messages(m => m.Select(CommonResource.SelectFile))
                .Name("PhysicalExaminationfiles")
                .ShowFileList(true)
                .Multiple(false)
                .Async(a => a
                .Save("AddPhysicalExaminationFile", "Attachment", new { fileGuid = Guid.NewGuid() })
                .AutoUpload(true)
                ).Events(c => c
                .Select("onSelectFileCustom")
                    .Success("onSuccessUploadPhysicalExaminationFile")))
                    }



                    <br />
                    @if (Model.PhysicalExaminationAttachmentId.HasValue)
                    {
                        @Model.PhysicalExaminationFilename <a href='@Url.Action("Download", "Attachment")?attachmentId=@HashIdsManager.Encrypt(Model.PhysicalExaminationAttachmentId.Value)'><i class='fa fa-download' style='color:black'></i></a>
                    }

                </div>
            </div>
        </div>
