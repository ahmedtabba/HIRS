                    @Html.EditorFor(m => m.Weight, new { htmlAttributes = new { @class = "form-control", @placeholder = PICUConsultationFormResource.Weight, @id = "Weight", @type = "number", min = "0", step = "1", onclick = "$(this).select();" } })
