        <div class="form-group row" style="margin-top:20px;">
            <div class="col-lg-4 @customeClass">
                @(Html.Kendo().DropDownListFor(x=>x.GeneralAppearance1)
          .DataTextField("Text")
          .DataValueField("Value")
          .OptionLabel(CommonResource.Select)
          .Enable(!viewMode)
          // .Events(e => e.Change("change"))
          .BindTo(new List<SelectListItem>() {
              new SelectListItem() {
                  Text = GeneralAppearance1.Well.GetDescription(),
                  Value = ((int)GeneralAppearance1.Well).ToString()
              },
               new SelectListItem() {
                  Text = GeneralAppearance1.Poor.GetDescription(),
                  Value = ((int)GeneralAppearance1.Poor).ToString()
              },
  new SelectListItem() {
                  Text = GeneralAppearance1.Grave.GetDescription(),
                  Value = ((int)GeneralAppearance1.Grave).ToString()
  }

          })
          .Value(((int?)Model.GeneralAppearance1).ToString())
          .HtmlAttributes(new { style = "width: 100%",@class="form-control custom-style" })
    )
                @Html.ValidationMessageFor(model => model.GeneralAppearance1)


            </div>

            <div class="col-lg-4 @customeClass">
                @(Html.Kendo().MultiSelectFor(x => x.GeneralAppearance2)
                                                                                                                                                      //.Name("BasicServices")
