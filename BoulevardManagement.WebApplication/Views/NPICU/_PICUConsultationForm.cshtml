                                                                                                                                                      .AutoBind(false)
                                                                                                                                                      .HtmlAttributes(new { style="width:100%",@class="form-control custom-style"})
                                                                                                                                                      .BindTo(EnumExtensions.GetSelectItemList(typeof(BoulevardManagement.DTO.GeneralAppearance2)).ToList())
                                                                                                                                                      .Value(EnumExtensions.GetSelectItemList(typeof(BoulevardManagement.DTO.GeneralAppearance2), Model.GeneralAppearance2).ToList())
