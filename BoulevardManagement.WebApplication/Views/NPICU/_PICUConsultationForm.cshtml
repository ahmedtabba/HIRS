                }
                else
                {
                    @Html.TextAreaFor(m => m.MainComplaint, new { @class = "form-control", @rows = "3", @placeholder = PICUConsultationFormResource.MainComplaint, @id = "MainComplaint" })
                    @Html.ValidationMessageFor(x => x.MainComplaint)
                    <span class="form-text text-muted">@PICUConsultationFormResource.MainComplaintInfoSpan</span>
                }

            </div>
        </div>

        <div class="form-group row" style="margin-top:20px;">
            <div class="col-lg-12">
                <label>@PICUConsultationFormResource.HistoryOfPresentIllness:</label>
