                }
                else
                {
                    @Html.EditorFor(m => m.BirthWeight, new { htmlAttributes = new { @class = "form-control int", @placeholder = NICUConsultationFormResource.BirthWeight, @id = "BirthWeight", @type = "number", min = "0", step = "1", onclick = "$(this).select();" } })
                    @Html.ValidationMessageFor(x => x.BirthWeight)
                    <span class="form-text text-muted">@NICUConsultationFormResource.BirthWeightInfoSpan</span>
                }

            </div>

        </div>

        <div class="form-group row">
            <div class="col-sm-12">
                <div class="form-group required" aria-required="true">
