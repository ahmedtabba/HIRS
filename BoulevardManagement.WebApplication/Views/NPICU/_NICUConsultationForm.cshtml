                    @Html.EditorFor(m => m.AgeAtAdmission, new { htmlAttributes = new { @class = "form-control", @placeholder = NICUConsultationFormResource.AgeAtAdmission, @id = "AgeAtAdmission" } })
                    @Html.ValidationMessageFor(x => x.AgeAtAdmission)
