@using BoulevardManagement.DTO;
@using BoulevardManagement.WebApplication.Resources;
@using TripleA.Utilities.HashidsNet;
@using BoulevardManagement.WebApplication.Models;
@model NICUConsultationFormDTO

<script type="text/javascript" src="~/Scripts/FileUpload.js"></script>

@{
    var customeClass = "";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }

    var viewMode = !User.IsInRole(RoleConsistent.NPICU.EditNICUConsultationForm) || Model.CaseStatus == CaseStatus.Closed;
    string radioMargin = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "margin-right:15px;" : "margin-left:15px;";

}
@if (viewMode)
{
    <style>
        input[type=number]::-webkit-inner-spin-button,
        input[type=number]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            margin: 0;
        }
    </style>
}


<!--begin::Form-->
@using (Html.BeginForm("UpdateNICUConsultationForm", "NPICU", FormMethod.Post, new { @id = "NICUConsultationFormId" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(x => x.Id)
    @Html.HiddenFor(x => x.NPICUId)
    @Html.HiddenFor(model => model.PhysicalExaminationAttachmentId)
    @Html.HiddenFor(model => model.HasPhysicalExaminationAttachment)
    @Html.HiddenFor(model => model.PhysicalExaminationFilename)
    @Html.HiddenFor(model => model.PhysicalExaminationFilePath)

    @Html.HiddenFor(model => model.NICUConsultationFormAttachmentId)
    @Html.HiddenFor(model => model.HasNICUConsultationFormAttachment)
    @Html.HiddenFor(model => model.NICUConsultationFormFilename)
    @Html.HiddenFor(model => model.NICUConsultationFormFilePath)

    <div class="card-header">
        <div class="card-title">
            <h3 class="card-label">

                @NICUConsultationFormResource.OnlineNICUConsultationForm


            </h3>
        </div>

    </div>


    <div class="card-body">

        <div class="form-group row" style="margin-top:20px;">
            <div class="col-lg-3">
                <label @*style="margin-bottom: 25px;"*@>@NICUConsultationFormResource.GestationalAge:</label>
                @if (viewMode)
                {
                    @Html.EditorFor(m => m.GestationalAge, new { htmlAttributes = new { @class = "form-control", @placeholder = NICUConsultationFormResource.GestationalAge, @id = "GestationalAge", @readonly = "readonly" } })
                }
                else
                {
                    @Html.EditorFor(m => m.GestationalAge, new { htmlAttributes = new { @class = "form-control", @placeholder = NICUConsultationFormResource.GestationalAge, @id = "GestationalAge" } })
                    @Html.ValidationMessageFor(x => x.GestationalAge)
                    <span class="form-text text-muted">@NICUConsultationFormResource.GestationalAgeInfoSpan</span>
                }

            </div>

            <div class="col-lg-3">
                <label style="font-size:0.96rem">@NICUConsultationFormResource.ChronologicalAge:</label>
                @if (viewMode)
                {
