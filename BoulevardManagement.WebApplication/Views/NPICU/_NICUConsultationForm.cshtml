                }
                else
                {
                    @Html.EditorFor(m => m.ChronologicalAge, new { htmlAttributes = new { @class = "form-control", @placeholder = NICUConsultationFormResource.ChronologicalAge, @id = "ChronologicalAge" } })
                    @Html.ValidationMessageFor(x => x.ChronologicalAge)
                    <span class="form-text text-muted">@NICUConsultationFormResource.ChronologicalAgeInfoSpan</span>
                }

            </div>

            <div class="col-lg-3">
                <label @*style="margin-bottom: 25px;"*@>@NICUConsultationFormResource.AgeAtAdmission:</label>
