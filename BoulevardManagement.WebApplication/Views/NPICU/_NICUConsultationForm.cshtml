                        <div class="form-group">
                            @Html.RadioButtonFor(c => c.BornPlace, BornPlace.Inborn, new { @class = "", @style = "height:10px;" }) <span style="font-weight:400">@BornPlace.Inborn.GetDescription()</span>
                            @Html.RadioButtonFor(c => c.BornPlace, BornPlace.Outborn, new { @class = "", @style = "height:10px;" + radioMargin }) <span style="font-weight:400">@BornPlace.Outborn.GetDescription()</span>
                            @Html.ValidationMessageFor(model => model.BornPlace)
                            <span class="form-text text-muted">@NICUConsultationFormResource.FromInfoSpan</span>

                        </div>
                    }


                </div>
            </div>

        </div>




        <div class="form-group row" style="margin-top:20px;">
