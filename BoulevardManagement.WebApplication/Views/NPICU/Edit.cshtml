        background-size: contain;
        outline: none;
    }

    .recbutton-sm {
        width: 20px;
        height: 20px;
        border: 0;
        border-radius: 35px;
        background-image: url('/assets/media//icons/record-btn.png');
        background-size: contain;
        outline: none;
    }


