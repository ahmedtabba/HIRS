<!--begin::Container-->
<div class="container">
    <div class="card-toolbar" style="display:flex; flex-direction:row-reverse; margin-bottom:20px;">
        @if (User.IsInRole(RoleConsistent.NPICU.EditSettings))
        {
            <a href="javascript:void(0);" onclick="openUpdateNPICUModal()" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
                <i class="fas fa-cog" style="margin:0; padding:0;"></i>
            </a>
        }
        <a href="javascript:void(0);" onclick="openNewZoomModal()" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
            <i class="fas fa-video" style="margin:0; padding:0;"></i>
        </a>
        @if (Model.Status == CaseStatus.Open && User.IsInRole(RoleConsistent.NPICU.Close))
        {
            <button id="close-case-btn" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
                <i class="fas fa-lock" style="margin:0; padding:0;"></i> @CommonResource.Close
            </button>
        }
        @if (Model.Status == CaseStatus.Closed && User.IsInRole(RoleConsistent.NPICU.ReOpen))
        {
            <button id="reopen-case-btn" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
                <i class="fas fa-list" style="margin:0; padding:0;"></i> @CommonResource.ShowClosures
            </button>
        }
        <a href="javascript:void(0)" onclick="backBtnClick()" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
            <i class="ki ki-long-arrow-back icon-sm"></i>@CommonResource.Back
        </a>

    </div>
    <!--Patient Info Start-->
    @{Html.RenderAction("RenderPatientInfoPartial", "Patient", new { patientId = (string)ViewBag.PatientId }); }
    <!--Patient Info End-->
    <!--Begin Grid Section-->
    <div id="grid-section">



    </div>
