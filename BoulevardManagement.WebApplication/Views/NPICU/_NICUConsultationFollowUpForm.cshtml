<script>

    $("#NICUConsultationFollowUpFormId").on("submit", function (e) {

            e.preventDefault();



       // console.log(formdata11);
            $.ajax({
                url: this.action,
                type: this.method,
                data: $(this).serialize(),
                success: function (data) {
                    if (data.Success) {
                        ShowSuccessfllyMsg(data.Message);
                        $('#main-content').load('@Url.Action("GetNICUConsultationFollowUpForm", "NPICU", new {followUpId="", telenicuId = HashIdsManager.Encrypt(Model.NPICUId) })', function () {});
                        $('#sticky-menu').load('@Url.Action("GetSickyMenu", "NPICU", new { telenicuId = HashIdsManager.Encrypt(Model.NPICUId) })', function () {
                            onmenueload();
                            $("#ConsultationFollowUpFormBtn").addClass("active");
                        });
                        refreshollowUPGrid();
                    } else {
                        onJSError(data.Message);
                        $("#save").removeAttr("disabled");
                    }
                }
            });




           // $("#ManifestItemFormId").submit();
    });

    $("#save").on("click", function (e) {

        //  $('#voice').val(formData);
        $('#NICUConsultationFollowUpFormId').validate();
        if ($("#NICUConsultationFollowUpFormId").valid()) {


            $("#save").attr("disabled", "disabled");



            $("#NICUConsultationFollowUpFormId").submit();
        }
    });

    $("#cancel").on("click", function (e) {
       $('#main-content').load('@Url.Action("GetNICUConsultationFollowUpForm", "NPICU", new {followUpId="", telenicuId = HashIdsManager.Encrypt(Model.NPICUId) })', function () { });
    });

    $("#AddFollowUpBtn").on("click", function () {
         $('#main-content').load('@Url.Action("GetNICUConsultationFollowUpFormForAdd", "NPICU", new { telenicuId = HashIdsManager.Encrypt(Model.NPICUId) })', function () {});

    });

    $("input[type=number]").on("keypress", function (evt) {

        //if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
        //    evt.preventDefault();
        //}

        if (evt.which == 101) {
            evt.preventDefault();
        }
    });

    $(".int").on("keypress", function (evt) {

        //if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
        //    evt.preventDefault();
        //}

        if (evt.which == 46 || evt.which == 101) {
            evt.preventDefault();
        }
    });


    $('#BPFirstPart').change(function () {
        debugger;
        var Firstvalue = $('#BPFirstPart').val();
        var Secondvalue = $('#BPSecondPart').val();
        var Result = (parseFloat(Firstvalue) + (2 * parseFloat(Secondvalue))) / 3;
        if (Firstvalue == null || Firstvalue == "" || Secondvalue == null || Secondvalue == "") {
            $('#Map').val('');
        } else {
            $('#Map').val(Result.toFixed(3));
        }

    });
    $('#BPSecondPart').change(function () {
        debugger;
        var Firstvalue = $('#BPFirstPart').val();
        var Secondvalue = $('#BPSecondPart').val();
        var Result = (parseFloat(Firstvalue) + (2 * parseFloat(Secondvalue))) / 3;
        if (Firstvalue == null || Firstvalue == "" || Secondvalue == null || Secondvalue == "") {
            $('#Map').val('');
        } else {
            $('#Map').val(Result.toFixed(3));
        }
    });
</script>

