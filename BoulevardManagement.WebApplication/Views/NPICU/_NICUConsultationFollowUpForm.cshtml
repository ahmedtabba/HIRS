@using BoulevardManagement.DTO;
@using BoulevardManagement.WebApplication.Resources;
@using TripleA.Utilities.HashidsNet;
@using BoulevardManagement.WebApplication.Models;
@model NICUConsultationFollowUpFormDTO


@{
    var customeClass = "";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }

    var viewMode = !User.IsInRole(RoleConsistent.NPICU.EditNICUConsultationFollowUpForm) || Model.CaseStatus == CaseStatus.Closed;
    if (Model.Id > 0)
    {
        viewMode = true;
    }

}
@if (Model.CaseStatus == CaseStatus.Closed)
{
    <style>

        .k-grid-NICUConsultationFollowUpFormDestroy {
            display: none !important;
        }
    </style>
}
@if (viewMode)
{
    <style>
        input[type=number]::-webkit-inner-spin-button,
        input[type=number]::-webkit-outer-spin-button {
            -webkit-appearance: none;
            -moz-appearance: none;
            appearance: none;
            margin: 0;
        }
    </style>
}
@if (Model.Id > 0 && Model.CaseStatus != CaseStatus.Closed && User.IsInRole(RoleConsistent.NPICU.EditNICUConsultationFollowUpForm))
{
    <button type="button" id="AddFollowUpBtn" class="btn btn-primary">@NICUConsultationFormFollowUPResource.AddFollowUp</button>
}

