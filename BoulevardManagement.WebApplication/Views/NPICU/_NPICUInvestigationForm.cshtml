@using BoulevardManagement.DTO;
@using BoulevardManagement.WebApplication.Resources;
@using TripleA.Utilities.HashidsNet;
@using BoulevardManagement.WebApplication.Models;
@model NPICUInvestigationDTO

@*<script type="text/javascript" src="~/Scripts/FileUpload.js"></script>*@
<script src="~/Scripts/FileUpload.js"></script>
<style>
    h4{
        text-align:center;
        margin-top:30px;
    }
</style>

@{
    var customeClass = "";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }

    var viewMode = !User.IsInRole(RoleConsistent.NPICU.EditNPICUInvestigation) || Model.CaseStatus == CaseStatus.Closed;
    if (Model.Id > 0)
    {
        viewMode = true;
    }
    string radioMargin = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "margin-right:15px;" : "margin-left:15px;";

}

@if (Model.CaseStatus == CaseStatus.Closed)
{
    <style>

        .k-grid-NPICUInvestigationDestroy {
            display: none !important;
        }
    </style>
}

@if (Model.Id > 0 && Model.CaseStatus != CaseStatus.Closed && User.IsInRole(RoleConsistent.NPICU.EditNPICUInvestigation))
{
    <button type="button" id="AddFollowUpBtn" class="btn btn-primary">@NPICUInvestigationResource.AddInvestigation</button>
}

<!--begin::Form-->
@using (Html.BeginForm("SaveNPICUInvestigation", "NPICU", FormMethod.Post, new { @id = "NPICUInvestigationFormId" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(x => x.Id)
    @Html.HiddenFor(x => x.NPICUId)

    @Html.HiddenFor(model => model.BloodGasesAttachmentId)
    @Html.HiddenFor(model => model.HasBloodGasesAttachment)
    @Html.HiddenFor(model => model.BloodGasesFilename)
    @Html.HiddenFor(model => model.BloodGasesFilePath)



    @Html.HiddenFor(model => model.CBCWithDifferentialAttachmentId)
    @Html.HiddenFor(model => model.HasCBCWithDifferentialAttachment)
    @Html.HiddenFor(model => model.CBCWithDifferentialFilename)
    @Html.HiddenFor(model => model.CBCWithDifferentialFilePath)



    @Html.HiddenFor(model => model.ElectrolytesAttachmentId)
    @Html.HiddenFor(model => model.HasElectrolytesAttachment)
    @Html.HiddenFor(model => model.ElectrolytesFilename)
    @Html.HiddenFor(model => model.ElectrolytesFilePath)


    @Html.HiddenFor(model => model.BiochemistryAttachmentId)
    @Html.HiddenFor(model => model.HasBiochemistryAttachment)
    @Html.HiddenFor(model => model.BiochemistryFilename)
    @Html.HiddenFor(model => model.BiochemistryFilePath)

    @Html.HiddenFor(model => model.CSFStudyAttachmentId)
    @Html.HiddenFor(model => model.HasCSFStudyAttachment)
    @Html.HiddenFor(model => model.CSFStudyFilename)
    @Html.HiddenFor(model => model.CSFStudyFilePath)


    @Html.HiddenFor(model => model.ChestAndAbdomenXrayAttachmentId)
    @Html.HiddenFor(model => model.HasChestAndAbdomenXrayAttachment)
    @Html.HiddenFor(model => model.ChestAndAbdomenXrayFilename)
    @Html.HiddenFor(model => model.ChestAndAbdomenXrayFilePath)

    @Html.HiddenFor(model => model.OtherInvestigationsAttachmentId)
    @Html.HiddenFor(model => model.HasOtherInvestigationsAttachment)
    @Html.HiddenFor(model => model.OtherInvestigationsFilename)
    @Html.HiddenFor(model => model.OtherInvestigationsFilePath)




    <div class="card-header">
        <div class="card-title">
            <h3 class="card-label">

                @NPICUInvestigationResource.Investigations


            </h3>
        </div>

    </div>


    <div class="card-body">
        <div class="row form-group" style="margin-top:-20px;">
            <div class="col-lg-12">
                <div class="required @customeClass">
                    <div class="k-widget k-tooltip-validation k-invalid-msg field-validation-error" style="margin: 0.5em; display: none; " id="BloodGasesfileserrorMessage">
                        <span class="fa fa-times-circle" style="margin-top:5px; color:#d9534f;"> </span><label id="BloodGasesfileserrorMsgTxt"></label>
                    </div>
                    @if (!viewMode)
                    {
                        @(Html.Kendo().Upload().Messages(m => m.Select(CommonResource.SelectFile))
                .Name("BloodGasesfiles")
                .ShowFileList(true)
                .Multiple(false)
                .Async(a => a
                .Save("AddBloodGasesFile", "Attachment", new { fileGuid = Guid.NewGuid() })
                .AutoUpload(true)
                ).Events(c => c
                .Select("onSelectFileCustom")
                    .Success("onSuccessUploadBloodGasesFile")))
                    }



                    <br />
                    @if (Model.BloodGasesAttachmentId.HasValue)
                    {
                        @Model.BloodGasesFilename <a href='@Url.Action("Download", "Attachment")?attachmentId=@HashIdsManager.Encrypt(Model.BloodGasesAttachmentId.Value)'><i class='fa fa-download' style='color:black'></i></a>
                    }

                </div>
            </div>
        </div>
        <div class="form-group row">
            <div class="col-sm-12">
                <div class="form-group required" aria-required="true">
                    @Html.Label(NPICUInvestigationResource.BloodGases + ":", new { @class = "control-label required" }) <span style="color:red">*</span>
                    @if (viewMode)
                    {
                        <div class="form-group">
                            @Model.BloodGases.GetDescription()
                        </div>
                    }
                    else
                    {
                        <div class="form-group">
                            @Html.RadioButtonFor(c => c.BloodGases, BloodGases.ABG, new { @class = "", @style = "height:10px;" }) <span style="font-weight:400">@BloodGases.ABG.GetDescription()</span>
                            @Html.RadioButtonFor(c => c.BloodGases, BloodGases.VBG, new { @class = "", @style = "height:10px;"+radioMargin }) <span style="font-weight:400">@BloodGases.VBG.GetDescription()</span>
                            @Html.RadioButtonFor(c => c.BloodGases, BloodGases.CBG, new { @class = "", @style = "height:10px;"+radioMargin }) <span style="font-weight:400">@BloodGases.CBG.GetDescription()</span>
                            @Html.ValidationMessageFor(model => model.BloodGases)
                            <span class="form-text text-muted">@NPICUInvestigationResource.BloodGasesInfoSpan</span>

                        </div>
                    }


                </div>
            </div>

        </div>

