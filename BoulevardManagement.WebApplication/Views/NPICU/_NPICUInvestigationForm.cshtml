            <div class="col-lg-12">
                <label>@NPICUInvestigationResource.Echocardiography:</label>
                @if (viewMode)
                {
                    @Html.TextAreaFor(m => m.Echocardiography, new { @class = "form-control", @rows = "3", @placeholder = NPICUInvestigationResource.Echocardiography, @id = "Echocardiography", @readonly = "readonly" })
                }
                else
                {
                    @Html.TextAreaFor(m => m.Echocardiography, new { @class = "form-control", @rows = "3", @placeholder = NPICUInvestigationResource.Echocardiography, @id = "Echocardiography" })
                    @Html.ValidationMessageFor(x => x.Echocardiography)
                    <span class="form-text text-muted">@NPICUInvestigationResource.EchocardiographyInfoSpan</span>
                }

            </div>
        </div>

        <div class="form-group row" style="margin-top:20px;">
            <div class="col-lg-12">
                <label>@NPICUInvestigationResource.Others:</label>
                @if (viewMode)
                {
                    @Html.TextAreaFor(m => m.Others, new { @class = "form-control", @rows = "3", @placeholder = NPICUInvestigationResource.Others, @id = "Others", @readonly = "readonly" })
                }
                else
                {
                    @Html.TextAreaFor(m => m.Others, new { @class = "form-control", @rows = "3", @placeholder = NPICUInvestigationResource.Others, @id = "Others" })
                    @Html.ValidationMessageFor(x => x.Others)
                    <span class="form-text text-muted">@NPICUInvestigationResource.OthersInfoSpan</span>
                }

            </div>

            <div class="col-lg-12">
                <div class="required @customeClass">
                    <div class="k-widget k-tooltip-validation k-invalid-msg field-validation-error" style="margin: 0.5em; display: none; " id="OtherInvestigationsfileserrorMessage">
                        <span class="fa fa-times-circle" style="margin-top:5px; color:#d9534f;"> </span><label id="OtherInvestigationsfileserrorMsgTxt"></label>
                    </div>
                    @if (!viewMode)
                    {
                        @(Html.Kendo().Upload().Messages(m => m.Select(CommonResource.SelectFile))
                .Name("OtherInvestigationsfiles")
                .ShowFileList(true)
                .Multiple(false)
                .Async(a => a
                .Save("AddOtherInvestigationsFile", "Attachment", new { fileGuid = Guid.NewGuid() })
                .AutoUpload(true)
                ).Events(c => c
                .Select("onSelectFileCustom")
                    .Success("onSuccessUploadOtherInvestigationsFile")))
                    }



                    <br />
                    @if (Model.OtherInvestigationsAttachmentId.HasValue)
                    {
                        <div style="margin-bottom:20px;">
                            @Model.OtherInvestigationsFilename <a href='@Url.Action("Download", "Attachment")?attachmentId=@HashIdsManager.Encrypt(Model.OtherInvestigationsAttachmentId.Value)'><i class='fa fa-download' style='color:black'></i></a>
                        </div>
                    }

                </div>
            </div>
        </div>

        @if (!viewMode)
        {
            <button type="button" id="save" class="btn btn-primary">@CommonResource.Save</button>
            <button type="button" id="cancel" class="btn btn-default">@CommonResource.Cancel</button>

        }



    </div>




}



<!--end::Form-->




