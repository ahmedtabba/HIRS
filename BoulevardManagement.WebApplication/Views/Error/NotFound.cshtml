@using BoulevardManagement.WebApplication.Resources; 
@model System.Web.Mvc.HandleErrorInfo

@{
    ViewBag.Title = "Not Found";
    //Layout = "~/Views/Shared/_Layout.cshtml";

}
<style>
    .error-area {
        height: 100vh;
    }
    .d-table {
        width: 100%;
        height: 100%;
    }
    .d-table {
        display: table !important;
    }
    .d-table-cell {
        vertical-align: middle;
    }
    .error-content {
        text-align: center;
        margin: 0 auto;
        max-width: 700px;
    }
    img {
        max-width: 100%;
        height: auto;
    }
    .error-content h3 {
        font-size: 50px;
        font-weight: 500;
        margin-top: 45px;
        margin-bottom: 15px;
    }
    h3 {
        color: #2f4858;
        text-transform: capitalize;
        font-family: "Rubik", sans-serif;
    }
    .error-content .default-btn {
        display: inline-block;
        background-color: #207ef7;
        padding: 14px 30px;
        border-radius: 30px;
        color: #ffffff;
        -webkit-transition: 0.5s;
        transition: 0.5s;
    }
    .error-content .default-btn {
        display: inline-block;
        background-color: #207ef7;
        padding: 14px 30px;
        border-radius: 30px;
        color: #ffffff;
        -webkit-transition: 0.5s;
        transition: 0.5s;
    }

    .default-btn {
        border: none;
        position: relative;
        display: inline-block;
        text-align: center;
        overflow: hidden;
        z-index: 1;
        text-transform: capitalize;
        background-color: #207ef7;
        color: #ffffff;
        -webkit-transition: 0.5s;
        transition: 0.5s;
        border-radius: 30px;
        opacity: 1;
        font-weight: 400;
        font-size: 15px;
        padding-left: 30px;
        padding-right: 30px;
        padding-top: 14px;
        padding-bottom: 14px;
    }
    .error-content .default-btn:hover {
        background-color: #6c9dfb;
    }

</style>
@if (!User.Identity.IsAuthenticated)
{
    <style>
        .topbar{
            display:none !important;
        }
        .header-menu{
            display:none;
        }
    </style>
}
<section class="error-area">
    <div class="d-table">
        <div class="d-table-cell">
            <div class="container">
                <div class="error-content">
                    <img src="~/Content/img/NotFound.png" alt="error">
                    <h3>@NotFoundResource.Title</h3>
                    <p style="color:grey;font-size:16px">@NotFoundResource.Descreption</p>
                    @if (User.Identity.IsAuthenticated)
                    {
                        <a href="/" class="default-btn" style="background-color:#ef4849">
                            @NotFoundResource.GoToHome
                            <span></span>
                        </a>
                    }

                </div>
            </div>
        </div>
    </div>
</section>

