@using BoulevardManagement.DTO;
@using TripleA.Utilities.HashidsNet;
@using BoulevardManagement.WebApplication.Resources;
@model TelICUPumpDTO


<style>
    .custom-style.k-datetimepicker .k-picker-wrap .k-icon {
        margin-top: 10px !important;
    }
</style>


@using (Html.BeginForm("UpdatePump", "TeleICU", FormMethod.Post, new { @id = "TelICUPumpFormId" }))
{
<div class="modal-body">

    @Html.AntiForgeryToken()
    <input type="hidden" id="Id" name="Id" value="@Model.Id" class="PumpId" />
    @Html.HiddenFor(x => x.TeleICUId)
    <div class="row">
        <div class="form-group col-lg-4">



            <label>@PumpFormResource.Date:</label>
            @(Html.Kendo().DateTimePicker().Format("dd/MM/yyyy hh:mm tt").TimeFormat("hh:mm tt")

                                  .Name("Pumpdatetime").Value(Model.PumpDate).Max(DateTime.Now)
                               .HtmlAttributes(new { @type = "text", @class = "form-control custom-style", title = "datepicker", @style = "width:100%" ,@id= "Pumpdatetime", onkeydown = "javascript:return false;" })

                            )
            <input hidden name="PumpDate" id="PumpDate" value="@Model.PumpDate" />
            @Html.ValidationMessageFor(x => x.PumpDate)
            <span class="form-text text-muted">@PumpFormResource.DateInfoSpan</span>
        </div>

        <div class="form-group col-lg-4">
            <label>@PumpFormResource.MedicationName:</label>
            @Html.EditorFor(m => m.MedicationName, new { htmlAttributes = new { @class = "form-control", @placeholder = @PumpFormResource.MedicationName, @id = "MedicationNamePump" } })
            @Html.ValidationMessageFor(x => x.MedicationName)
            <span class="form-text text-muted">@PumpFormResource.MedicationNameInfoSpan</span>
        </div>

        <div class="form-group col-lg-4">
            <label>
                @PumpFormResource.FlowRate:
            </label>
            @Html.EditorFor(m => m.FlowRate, new { htmlAttributes = new { @class = "form-control", @placeholder = @PumpFormResource.FlowRate, @id = "FlowRate" } })
            @Html.ValidationMessageFor(x => x.FlowRate)
            <span class="form-text text-muted">@PumpFormResource.FlowRateInfoSpan</span>
        </div>




    </div>

    <div class="row">
        <div class="form-group col-lg-12">
            <label>@PumpFormResource.Notes:</label>

            @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", @rows = "3", @placeholder = PumpFormResource.Notes, @id = "Notespump" })
            @Html.ValidationMessageFor(x => x.Notes)
            <span class="form-text text-muted">@PumpFormResource.NotesInfoSpan</span>


        </div>
    </div>



</div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">@CommonResource.Cancel</button>
        <button type="button" id="savepumpform" class="btn btn-primary">@CommonResource.Save</button>
    </div>
}



<script src="~/Scripts/jquery.validate-vsdoc.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<script>
    $("#TelICUPumpFormId").on("submit", function (e) {
        
        $("#PumpDate").val($('#Pumpdatetime').val());
        e.preventDefault();
        $.ajax({
            url: this.action,
            type: this.method,
            data: $(this).serialize(),
            success: function (data) {
                if (data.Success) {
                    ShowSuccessfllyMsg(data.Message);
                    $("#AddPumpModal").modal("hide");
                    $("#TelICUPumpGrid").data("kendoGrid").dataSource.read();
                    $("#TelICUPumpGrid").data("kendoGrid").refresh();
                } else {
                    onJSError(data.Message);
                    $("#savepumpform").removeAttr("disabled");
                }
            }
        });




        // $("#ManifestItemFormId").submit();
    });

    $("#savepumpform").on("click", function (e) {
        
        $('#TelICUPumpFormId').validate();

        if ($("#TelICUPumpFormId").valid()) {



            $("#savepumpform").attr("disabled", "disabled");



            $("#TelICUPumpFormId").submit();
        }
    });
    $('#AddPumpModal').on('hidden.bs.modal', function (e) {
        debugger;
        $('.PumpId').val(0);
        $('#MedicationNamePump').val('');
        $('#FlowRate').val('');
        $('#Notespump').val('');

        $("#savepumpform").removeAttr("disabled");

    })
    $("input[type=number]").on("keypress", function (evt) {
        
        if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
            evt.preventDefault();
        }
    });
</script>