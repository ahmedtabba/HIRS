    function onSuccessUploadPledgeDocumentFile(e) {

        UploadedFile = getFileInfo(e);
        UploadedFilePath = e.response.filePath;
        if (UploadedFile)
            $('#HasNewPledgeDocumentAttachment').val(true);

        if (UploadedFile)
            $('#PledgeDocumentFilename').val(UploadedFile);

        if (UploadedFilePath)
            $('#PledgeDocumentFilePath').val(UploadedFilePath);
    }

