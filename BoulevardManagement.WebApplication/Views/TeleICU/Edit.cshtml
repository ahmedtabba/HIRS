
@using BoulevardManagement.DTO;
@using BoulevardManagement.WebApplication.Resources;
@using BoulevardManagement.DTO.Utilities;
@model TeleICUDTO
<style>
    .recbutton {
        width: 35px;
        height: 35px;
        //background-color: red;
        border: 0;
        border-radius: 35px;
        background-image: url('/assets/media//icons/record-btn.png');
        background-size: contain;
        outline: none;
    }

    .recbutton-sm {
        width: 20px;
        height: 20px;
        border: 0;
        border-radius: 35px;
        background-image: url('/assets/media//icons/record-btn.png');
        background-size: contain;
        outline: none;
    }


    .notRec {
        // background-color: darkred;
    }

    .Rec {
        animation-name: pulse;
        animation-duration: 1.5s;
        animation-iteration-count: infinite;
        animation-timing-function: linear;
    }

    .recordsection {
        list-style-type: none;
        text-align: left;
        padding: 0px;
        margin-top: 10px;
    }

        .recordsection li audio {
            width: 100%;
            height: 40px;
        }

    .recycler {
        color: red;
    }
</style>
@if (Model.Status == CaseStatus.Closed)
{
    <style>
        .ChatReplySection, .ChatSendSection {
            display: none !important;
        }
    </style>
}
<div id="sticky-menu" class="" style="">
</div>

<!--begin::Container-->
<div class="container">
    <div class="card-toolbar" style="display:flex; flex-direction:row-reverse; margin-bottom:20px;">
        @if (User.IsInRole(RoleConsistent.TeleICU.EditSettings))
        {
            <a href="javascript:void(0);" onclick="openUpdateICUModal()" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
                <i class="fas fa-cog" style="margin:0; padding:0;"></i>
            </a>
        }

        <a href="javascript:void(0);" onclick="openNewZoomModal()" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
            <i class="fas fa-video" style="margin:0; padding:0;"></i>
        </a>
        @if (Model.Status == CaseStatus.Open && User.IsInRole(RoleConsistent.TeleICU.Close))
        {
            <button id="close-case-btn" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
                <i class="fas fa-lock" style="margin:0; padding:0;"></i> @CommonResource.Close
            </button>
        }
        @if (Model.Status == CaseStatus.Closed && User.IsInRole(RoleConsistent.TeleICU.ReOpen))
        {
            <button id="reopen-case-btn" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
                <i class="fas fa-list" style="margin:0; padding:0;"></i> @CommonResource.ShowClosures
            </button>
        }
        <a href="javascript:void(0)" onclick="backBtnClick()" class="btn btn-light-primary font-weight-bolder mr-2 pull-right">
            <i class="ki ki-long-arrow-back icon-sm"></i>@CommonResource.Back
        </a>

    </div>
    <!--Patient Info Start-->
    @{Html.RenderAction("RenderPatientInfoPartial", "Patient", new { patientId = (string)ViewBag.PatientId }); }
    <!--Patient Info End-->
    <div id="grid-section">



    </div>
    <div class="card card-custom" id="main-content">


    </div>
</div>
<!--end::Container-->
