<script>
    var isRecordPressed = false;
    var isStop = false;
    var BufferVoiceMessage;
    var BufferVoiceMessageForRemark;
    var IsModalClosePressed = false;
    var myFileRemarks;
    var myFileCurrentComplaint;
    var MyFileRiskAssessment;
    var MyFileCaseSummary;

    var PressedRecordButton="";
        $(document).ready(function () {

        if ('@viewMode'=='True') {
            $('#TelICULabUnitFormId input').attr('readonly', 'readonly');
            $('#TelICULabUnitFormId textarea').attr('readonly', 'readonly');
           // document.getElementById("IsThereAnAllergyToDrugs").disabled = true;
            $('select').attr('disabled', 'disabled');
        }
    });
    //var myblob;
    $("#TelICULabUnitFormId").on("submit", function (e) {

            e.preventDefault();
        var formData = new FormData();


        var formdataSerialize = $(this).serializeArray();
        for (var i = 0; i < formdataSerialize.length; i++) {

            formData.append(formdataSerialize[i].name, formdataSerialize[i].value);
        }


       // console.log(formdata11);
            $.ajax({
                url: "@(Url.Action("UpdateLabUnit", "TeleICU"))",
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Success) {
                        ShowSuccessfllyMsg(data.Message);
                        $('#main-content').load('@Url.Action("GetLabUnit", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {});
                        $('#sticky-menu').load('@Url.Action("GetSickyMenu", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {
                            onmenueload();
                            $("#LabUnitBtn").addClass("active");

                        });
                        refreshLabUnitGrid();
                    } else {
                        onJSError(data.Message);
                        $("#savelabunit").removeAttr("disabled");
                    }
                }
            });




           // $("#ManifestItemFormId").submit();
    });

    $("#savelabunit").on("click", function (e) {

          //  $('#voice').val(formData);
        $('#TelICULabUnitFormId').validate();
        if ($("#TelICULabUnitFormId").valid()) {
            $("#savelabunit").attr("disabled", "disabled");



            $("#TelICULabUnitFormId").submit();
        }
    });
    $("input[type=text]").on("keypress", function (evt) {

        if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
            if (evt.which==46) {
                return;
            }
            evt.preventDefault();
        }
    });
    $("input[type=number]").on("keypress", function (evt) {


        if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
            if (evt.which == 45 || evt.which == 43) {
                return;
            }
            evt.preventDefault();
        }
    });
     $("#AddTeleIcuBtn").on("click", function () {
         $('#main-content').load('@Url.Action("GetTelIcuLabUnitForAdd", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {});

     });
                        $("#cancel").on("click", function (e) {
       $('#main-content').load('@Url.Action("GetLabUnit", "TeleICU", new { labUnitId = "", ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () { });
    });
</script>
