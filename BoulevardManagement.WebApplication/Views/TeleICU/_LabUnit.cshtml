@using BoulevardManagement.DTO;
@using BoulevardManagement.WebApplication.Resources;
@using TripleA.Utilities.HashidsNet;
@model TelICULabUnitDTO


@{
    var customeClass = "";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }

    var viewMode = !User.IsInRole(RoleConsistent.TelIcuLabUnit.EditLabUnit) || Model.CaseStatus == CaseStatus.Closed;
    if (Model.Id > 0)
    {
        viewMode = true;
    }
    string radioMargin = System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft ? "margin-right:15px;" : "margin-left:15px;";

}

<style>
    td {
        border: 1px solid #EBEDF3;
        vertical-align: middle !important;
    }
</style>
@if (Model.CaseStatus == CaseStatus.Closed)
{
    <style>
        .k-grid-TelIcuLabUnitDestroy {
            display: none !important;
        }
    </style>
}
@if (Model.Id > 0 && Model.CaseStatus != CaseStatus.Closed && User.IsInRole(RoleConsistent.TelIcuLabUnit.EditLabUnit))
{
    <button type="button" id="AddTeleIcuBtn" class="btn btn-primary">@ICULabUnitResource.AddLabUnit</button>
}
<script type="text/javascript" src="~/Scripts/FileUpload.js"></script>

