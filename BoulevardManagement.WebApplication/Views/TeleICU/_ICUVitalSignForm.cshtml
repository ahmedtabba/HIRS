

@using BoulevardManagement.DTO;
@using TripleA.Utilities.HashidsNet;
@using BoulevardManagement.WebApplication.Resources;
@model TelICUVitalSignDTO


<style>
    .custom-style.k-datetimepicker .k-picker-wrap .k-icon {
        margin-top: 10px !important;
    }
</style>
@using (Html.BeginForm("UpdateVitalSign", "TeleICU", FormMethod.Post, new { @id = "TelICUVitalSignFormId" }))
{
<div class="modal-body">

    @Html.AntiForgeryToken()
    <input type="hidden" id="Id" name="Id" value="@Model.Id" class="VitalSignId" />
    @Html.HiddenFor(x => x.TeleICUId)
    <div class="row">
        <div class="form-group col-lg-4">



            <label>@ICUVitalSignFormResource.VitalSignDate:</label>
            @(Html.Kendo().DateTimePicker().Format("dd/MM/yyyy hh:mm tt").TimeFormat("hh:mm tt")

                                  .Name("VitalSigndatetime").Value(Model.VitalSignDate).Max(DateTime.Now)
                               .HtmlAttributes(new { @type = "text", @class = "form-control custom-style", title = "datepicker", @style = "width:100%" ,@id= "VitalSigndatetime", onkeydown = "javascript:return false;" })

                            )
            <input hidden name="VitalSignDate" id="VitalSignDate" value="@Model.VitalSignDate" />
            @Html.ValidationMessageFor(x => x.VitalSignDate)
            <span class="form-text text-muted">@ICUVitalSignFormResource.VitalSignDateInfoSpan</span>
        </div>

        <div class="form-group col-lg-4">
            <label>@ICUVitalSignFormResource.Heat:</label>
            @Html.EditorFor(m => m.Heat, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.Heat, @id = "Heat" } })
            @Html.ValidationMessageFor(x => x.Heat)
            <span class="form-text text-muted">@ICUVitalSignFormResource.HeatInfoSpan</span>
        </div>

        <div class="form-group col-lg-4">
            <label>
                @ICUVitalSignFormResource.Pressure:
            </label>
            @Html.EditorFor(m => m.Pressure, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.Pressure, @id = "Pressure" } })
            @Html.ValidationMessageFor(x => x.Pressure)
            <span class="form-text text-muted">@ICUVitalSignFormResource.PressureInfoSpan</span>
        </div>




    </div>
    <div class="row">
        <div class="form-group col-lg-4">
            <label>@ICUVitalSignFormResource.Pulse:</label>
            @Html.EditorFor(m => m.Pulse, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.Pulse, @id = "Pulse" } })
            @Html.ValidationMessageFor(x => x.Pulse)
            <span class="form-text text-muted">@ICUVitalSignFormResource.PulseInfoSpan</span>
        </div>
        <div class="form-group col-lg-4">
            <label>@ICUVitalSignFormResource.Oxygenation:</label>
            @Html.EditorFor(m => m.Oxygenation, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.Oxygenation, @id = "Oxygenation" } })
            @Html.ValidationMessageFor(x => x.Oxygenation)
            <span class="form-text text-muted">@ICUVitalSignFormResource.OxygenationInfoSpan</span>
        </div>
        <div class="form-group col-lg-4">
            <label>@ICUVitalSignFormResource.BloodGlucoseLevels:</label>
            @Html.EditorFor(m => m.BloodGlucoseLevels, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.BloodGlucoseLevels, @id = "BloodGlucoseLevels" } })
            @Html.ValidationMessageFor(x => x.BloodGlucoseLevels)
            <span class="form-text text-muted">@ICUVitalSignFormResource.BloodGlucoseLevelsInfoSpan</span>
        </div>




    </div>

    <div class="row">
        <div class="form-group col-lg-4">
            <label>
                @ICUVitalSignFormResource.EmptyingOfUrine:
            </label>
            @Html.EditorFor(m => m.EmptyingOfUrine, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.EmptyingOfUrine, @id = "EmptyingOfUrine" } })
            @Html.ValidationMessageFor(x => x.EmptyingOfUrine)
            <span class="form-text text-muted">@ICUVitalSignFormResource.EmptyingOfUrineInfoSpan</span>
        </div>
        <div class="form-group col-lg-4">
            <label>
                @ICUVitalSignFormResource.Drain:
            </label>
            @Html.EditorFor(m => m.Drain, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.Drain, @id = "Drain" } })
            @Html.ValidationMessageFor(x => x.Drain)
            <span class="form-text text-muted">@ICUVitalSignFormResource.DrainInfoSpan</span>
        </div>

        <div class="form-group col-lg-4">
            <label>
                @ICUVitalSignFormResource.SecondDrain:
            </label>

            @Html.EditorFor(m => m.SecondDrain, new { htmlAttributes = new { @class = "form-control", @placeholder = @ICUVitalSignFormResource.SecondDrain, @id = "SecondDrain" } })
            @Html.ValidationMessageFor(x => x.SecondDrain)
            <span class="form-text text-muted">@ICUVitalSignFormResource.SecondDrainInfoSpan</span>
        </div>


    </div>
    <div class="row">
        <div class="form-group col-lg-12">
            <label>@ICUVitalSignFormResource.Notes:</label>

            @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", @rows = "3", @placeholder = @ICUVitalSignFormResource.Notes, @id = "NotesVitalSign" })
            @Html.ValidationMessageFor(x => x.Notes)
            <span class="form-text text-muted">@ICUVitalSignFormResource.NotesInfoSpan</span>


        </div>
    </div>

</div>
    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-dismiss="modal">@CommonResource.Cancel</button>
        <button type="button" id="savevitalsignform" class="btn btn-primary">@CommonResource.Save</button>
    </div>
}



<script src="~/Scripts/jquery.validate-vsdoc.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<script>
    $("#TelICUVitalSignFormId").on("submit", function (e) {
        
        $("#VitalSignDate").val($('#VitalSigndatetime').val());
        e.preventDefault();
        $.ajax({
            url: this.action,
            type: this.method,
            data: $(this).serialize(),
            success: function (data) {
                if (data.Success) {
                    ShowSuccessfllyMsg(data.Message);
                    $("#AddVitalSignModal").modal("hide");
                    $("#TelICUVitalSignGrid").data("kendoGrid").dataSource.read();
                    $("#TelICUVitalSignGrid").data("kendoGrid").refresh();
                } else {
                    onJSError(data.Message);
                    $("#savevitalsignform").removeAttr("disabled");
                }
            }
        });




        // $("#ManifestItemFormId").submit();
    });

    $("#savevitalsignform").on("click", function (e) {
        
        $('#TelICUVitalSignFormId').validate();

        if ($("#TelICUVitalSignFormId").valid()) {



            $("#savevitalsignform").attr("disabled", "disabled");



            $("#TelICUVitalSignFormId").submit();
        }
    });
    $('#AddVitalSignModal').on('hidden.bs.modal', function (e) {
        $('.VitalSignId').val(0);
        $('#Heat').val('');
        $('#Pressure').val('');
        $('#Pulse').val('');
        $('#Oxygenation').val('');
        $('#BloodGlucoseLevels').val('');
        $('#EmptyingOfUrine').val('');
        $('#Drain').val('');
        $('#SecondDrain').val('');
        $('#NotesVitalSign').val('');
        //$(this)
        //    .find("input,textarea,select")
        //    .val('')
        //    .end()
        //    .find("input[type=checkbox], input[type=radio]")
        //    .prop("checked", "")
        //    .end();
        $("#savevitalsignform").removeAttr("disabled");

    })
    $("input[type=number]").on("keypress", function (evt) {
        
        if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
            evt.preventDefault();
        }
    });
</script>