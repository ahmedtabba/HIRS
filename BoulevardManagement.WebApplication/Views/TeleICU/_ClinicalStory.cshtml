                </div>




            }



<!--end::Form-->




<script src="~/Scripts/jquery.validate-vsdoc.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<script>
    var isRecordPressed = false;
    var isStop = false;
    var BufferVoiceMessage;
    var BufferVoiceMessageForRemark;
    var IsModalClosePressed = false;
    var myFileRemarks;
    var myFileCurrentComplaint;
    var MyFileRiskAssessment;
    var MyFileCaseSummary;

    var PressedRecordButton="";
    $(document).ready(function () {

        if ('@viewMode'=='True') {
            $('#TelICUClinicalStoryFormId input').attr('readonly', 'readonly');
            $('#TelICUClinicalStoryFormId textarea').attr('readonly', 'readonly');
            document.getElementById("IsThereAnAllergyToDrugs").disabled = true;
        }
    });
    //var myblob;
    $("#TelICUClinicalStoryFormId").on("submit", function (e) {

            e.preventDefault();
        var formData = new FormData();


        var formdataSerialize = $(this).serializeArray();
        for (var i = 0; i < formdataSerialize.length; i++) {

            formData.append(formdataSerialize[i].name, formdataSerialize[i].value);
        }


       // console.log(formdata11);
            $.ajax({
                url: "@(Url.Action("UpdateClinicalStory", "TeleICU"))",
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Success) {
                        ShowSuccessfllyMsg(data.Message);
                        $('#main-content').load('@Url.Action("GetClinicalStory", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {});
                        $('#sticky-menu').load('@Url.Action("GetSickyMenu", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {
                            onmenueload();
                            $("#ClinicalStoryBtn").addClass("active");
                        });
                    } else {
                        onJSError(data.Message);
                        $("#save").removeAttr("disabled");
                    }
                }
            });




           // $("#ManifestItemFormId").submit();
    });

        $("#save").on("click", function (e) {
            debugger;
          //  $('#voice').val(formData);
            $('#TelICUClinicalStoryFormId').validate();
            var RiskFactors = $("#RiskFactors").data("kendoMultiSelect").value();
            if (RiskFactors.length==0) {
                $('#RiskFactorValidation').text('@CommonResource.RequiredFeild');
                onJSError('@CommonResource.SomeFeildIsRequired');
                return;
            }
            if ($("#TelICUClinicalStoryFormId").valid()) {
                if (RiskFactors.length != 0) {
                    $("#save").attr("disabled", "disabled");
                    $("#TelICUClinicalStoryFormId").submit();
                }

            } else {
                onJSError('@CommonResource.SomeFeildIsRequired');
            }
        });


    $('#RecordModal').on('hidden.bs.modal', function () {
        var recordingsList = document.getElementById("recordingsList");
        recordingsList.innerHTML = "";
        $(".recordButtonClass").removeClass("Rec");
        $(".recordButtonClass").addClass("notRec");
        $(".recordReplyButtonClass").removeClass("Rec");
        $(".recordReplyButtonClass").addClass("notRec");
      //  BufferVoiceMessage = null;
        if (IsModalClosePressed) {
            stopRecordingForClose();
        }
        var seconds = $("#secondsrecord");
        var minutes = $("#minutesrecord");

        seconds.text("00");
        minutes.text("00");
    });
    $('#RecordModal').on('shown.bs.modal', function () {
        IsModalClosePressed = false;
        var recordingsList = document.getElementById("recordingsList");
        recordingsList.innerHTML = "";
        BufferVoiceMessage = null;
        IsStop = false;
        var minuts = $("#secondsrecord");
        var seconds = $("#secondsrecord");
        var minutes = $("#minutesrecord");

        //   seconds.text("00");
        // minutes.text("00");
    });

    $("#RemarksVoiceRecorder").on("click", function () {
        PressedRecordButton = "Remarks";
    });

    $("#CurrentComplaintRecorder").on("click", function () {
        PressedRecordButton = "CurrentComplaint";
    });
    $("#RiskAssessmentRecorder").on("click", function () {
        PressedRecordButton = "RiskAssessment";
    });
    $("#CaseSummaryRecorder").on("click", function () {
        PressedRecordButton = "CaseSummary";
    });
    $('#RemarkrecordTrash').on("click", function () {

        $('#RemarksVoiceRecorder').show();
        $('#Remarkrecord').html('');
        $('#RemarkrecordTrash').hide();
        myFileRemarks = null;
        $('#IsRemarksVoiceDeleted').val(true);
    });
    $('#CurrentComplaintTrash').on("click", function () {

