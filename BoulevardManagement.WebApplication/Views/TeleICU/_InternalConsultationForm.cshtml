@using BoulevardManagement.DTO;
@using BoulevardManagement.WebApplication.Resources;
@using TripleA.Utilities.HashidsNet;
@model TelICUInternalConsultationFormDTO


@{
    var customeClass = "";
    if (System.Globalization.CultureInfo.CurrentCulture.TextInfo.IsRightToLeft)
    {
        customeClass = "k-rtl";
    }

    var viewMode = !User.IsInRole(RoleConsistent.TelIcuInternalConsultationForm.EditInternalConsultationForm) || Model.CaseStatus == CaseStatus.Closed;

}
@if (viewMode)
{
    <style>
        .viewMode {
            display: none;
        }
    </style>


}
<!--begin::Form-->
@using (Html.BeginForm("UpdateInternalConsultationForm", "TeleICU", FormMethod.Post, new { @id = "TelICUInternalConsultationFormFormId", enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()
    @Html.HiddenFor(x => x.Id)
    @Html.HiddenFor(x => x.TeleICUId)

    @*<input id="voice" name="voice" type="file" style="display:none" />*@

    <div class="card-header">
        <div class="card-title">
            <h3 class="card-label">
                @ICUInternalConsultationFormResource.InternalConsultationForm
            </h3>
        </div>
        @*<div class="card-toolbar">
                <a href="#" class="btn btn-light-primary font-weight-bolder mr-2">
                    <i class="ki ki-long-arrow-back icon-sm"></i>@CommonResource.Back
                </a>
                <a href="javascript:void(0);" class="btn btn-icon btn-circle btn-sm btn-light-primary mr-1" data-card-tool="toggle">
                    <i class="ki ki-arrow-down icon-nm"></i>
                </a>
            </div>*@
    </div>


    <div class="card-body">


        <div class="form-group row" style="margin-top:20px;">
            <div class="col-lg-6">
                <label>@ICUInternalConsultationFormResource.Diagnosis:</label>
                @Html.TextAreaFor(m => m.Diagnosis, new { @class = "form-control", @rows = "3", @placeholder = ICUInternalConsultationFormResource.Diagnosis, @id = "Diagnosis" })
                @Html.ValidationMessageFor(x => x.Diagnosis)
                <span class="form-text text-muted viewMode">@ICUInternalConsultationFormResource.DiagnosisInfoSpan</span>
            </div>
            <div class="col-lg-6">
                <label>@ICUInternalConsultationFormResource.DateOfSurgery:</label>
                @(Html.Kendo().DatePickerFor(c=>c.DateOfSurgery)
        .Format("dd/MM/yyyy")
              .Culture("en-US")
              .ParseFormats(new List<string>() { "dd/MM/yyyy" })
        .Value(Model.DateOfSurgery)
        .Max(DateTime.Now).
        Enable(!viewMode).DateInput(true)
                               .HtmlAttributes(new { @type = "text", @class = "form-control custom-style", title = "datepicker", @style = "width:100%" ,@id= "DateOfSurgery" })

                            )                    @Html.ValidationMessageFor(x => x.DateOfSurgery)
                            <span class="form-text text-muted viewMode">@ICUInternalConsultationFormResource.DateOfSurgeryInfoSpan</span>
                        </div>




                    </div>
                    <div class="form-group row" style="margin-top:20px;">
                        <div class="col-lg-6">
                            <label>@ICUInternalConsultationFormResource.NameOfDoctor:</label>
                            @Html.EditorFor(m => m.NameOfDoctor, new { htmlAttributes = new { @class = "form-control", @placeholder = ICUInternalConsultationFormResource.NameOfDoctor, @id = "NameOfDoctor" } })
                            @Html.ValidationMessageFor(x => x.NameOfDoctor)
                            <span class="form-text text-muted viewMode">@ICUInternalConsultationFormResource.NameOfDoctorInfoSpan</span>
                        </div>
                        <div class="col-lg-6">
                            <label>@ICUInternalConsultationFormResource.UndeAnesthesia:</label>
                            @(Html.Kendo().DropDownListFor(x=>x.UndeAnesthesia)
        .DataTextField("Text")
        .DataValueField("Value")
        .Filter("contains")
        .OptionLabel(CommonResource.Select).Enable(!viewMode)
        //.Events(ev => ev.Change("onChange"))
        .DataSource(source =>
        {
            source.Read(read =>
            {
                read.Action("GetUnderAnesthesiaEnumList", "TeleICU");
            }).ServerFiltering(false);
        }).HtmlAttributes(new{@class = "form-control custom-style", @id= "UndeAnesthesia", @style = "width:100%"})
        .AutoBind(true)
        .ValuePrimitive(true)
        .Value(Model.Id>0? Model.UndeAnesthesia.ToString():""))

                            @Html.ValidationMessageFor(x => x.UndeAnesthesia)

                            <span class="form-text text-muted viewMode">@ICUInternalConsultationFormResource.UndeAnesthesiaInfoSpan</span>
                        </div>
                    </div>
                    <div class="form-group row">
                        <div class="col-lg-12">
                            <label>@ICUInternalConsultationFormResource.Recommendations:</label>

                            @Html.TextAreaFor(m => m.Recommendations, new { @class = "form-control", @rows = "3", @placeholder = ICUInternalConsultationFormResource.Recommendations, @id = "Recommendations" })
                            @Html.ValidationMessageFor(x => x.Recommendations)
                            <span class="form-text text-muted viewMode">@ICUInternalConsultationFormResource.RecommendationsInfoSpan</span>


                        </div>

                    </div>

                    <br />
                    <br />
                    @if (!viewMode)
                    {
                        <button type="button" id="saveinternalform" class="btn btn-primary">@CommonResource.Save</button>
                    }


                    <!--<a href="#" class="btn btn-icon btn-warning btn-circle btn-lg" style="position:fixed; bottom:60px; right:115px;">
                    <span class="svg-icon">-->
                    <!--begin::Svg Icon | path:assets/media/svg/icons/Design/PenAndRuller.svg-->
                    <!--<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="24px" height="24px" viewBox="0 0 24 24" version="1.1">
                        <g stroke="none" stroke-width="1" fill="none" fill-rule="evenodd">
                            <rect x="0" y="0" width="24" height="24"></rect>
                            <path d="M3,16 L5,16 C5.55228475,16 6,15.5522847 6,15 C6,14.4477153 5.55228475,14 5,14 L3,14 L3,12 L5,12 C5.55228475,12 6,11.5522847 6,11 C6,10.4477153 5.55228475,10 5,10 L3,10 L3,8 L5,8 C5.55228475,8 6,7.55228475 6,7 C6,6.44771525 5.55228475,6 5,6 L3,6 L3,4 C3,3.44771525 3.44771525,3 4,3 L10,3 C10.5522847,3 11,3.44771525 11,4 L11,19 C11,19.5522847 10.5522847,20 10,20 L4,20 C3.44771525,20 3,19.5522847 3,19 L3,16 Z" fill="#000000" opacity="0.3"></path>
                            <path d="M16,3 L19,3 C20.1045695,3 21,3.8954305 21,5 L21,15.2485298 C21,15.7329761 20.8241635,16.200956 20.5051534,16.565539 L17.8762883,19.5699562 C17.6944473,19.7777745 17.378566,19.7988332 17.1707477,19.6169922 C17.1540423,19.602375 17.1383289,19.5866616 17.1237117,19.5699562 L14.4948466,16.565539 C14.1758365,16.200956 14,15.7329761 14,15.2485298 L14,5 C14,3.8954305 14.8954305,3 16,3 Z" fill="#000000"></path>
                        </g>
                    </svg>-->
                    <!--end::Svg Icon-->
                    <!--</span>
                    </a>-->

                </div>




            }



<!--end::Form-->




<script src="~/Scripts/jquery.validate-vsdoc.js"></script>
<script src="~/Scripts/jquery.validate.js"></script>
<script src="~/Scripts/jquery.validate.min.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.js"></script>
<script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>

<script>
    var isRecordPressed = false;
    var isStop = false;
    var BufferVoiceMessage;
    var BufferVoiceMessageForRemark;
    var IsModalClosePressed = false;
    var myFileRemarks;
    var myFileCurrentComplaint;
    var MyFileRiskAssessment;
    var MyFileCaseSummary;

    var PressedRecordButton="";
         $(document).ready(function () {

        if ('@viewMode'=='True') {
            $('#TelICUInternalConsultationFormFormId input').attr('readonly', 'readonly');
            $('#TelICUInternalConsultationFormFormId textarea').attr('readonly', 'readonly');
           // document.getElementById("IsThereAnAllergyToDrugs").disabled = true;
            $('select').attr('disabled', 'disabled');
        }
    });
    //var myblob;
    $("#TelICUInternalConsultationFormFormId").on("submit", function (e) {

            e.preventDefault();
        var formData = new FormData();


        var formdataSerialize = $(this).serializeArray();
        for (var i = 0; i < formdataSerialize.length; i++) {

            formData.append(formdataSerialize[i].name, formdataSerialize[i].value);
        }


       // console.log(formdata11);
            $.ajax({
                url: "@(Url.Action("UpdateInternalConsultationForm", "TeleICU"))",
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Success) {
                        ShowSuccessfllyMsg(data.Message);
                        $('#main-content').load('@Url.Action("GetInternalConsultationForm", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {});
                        $('#sticky-menu').load('@Url.Action("GetSickyMenu", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {
                            onmenueload();
                            $("#InternalConsultationFormBtn").addClass("active");
                        });
                    } else {
                        onJSError(data.Message);
                        $("#saveinternalform").removeAttr("disabled");
                    }
                }
            });




           // $("#ManifestItemFormId").submit();
    });

    $("#saveinternalform").on("click", function (e) {

          //  $('#voice').val(formData);
        $('#TelICUInternalConsultationFormFormId').validate();
        if ($("#TelICUInternalConsultationFormFormId").valid()) {
            $("#saveinternalform").attr("disabled", "disabled");



            $("#TelICUInternalConsultationFormFormId").submit();
        }
        });

    $("input[type=number]").on("keypress", function (evt) {

        if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
            evt.preventDefault();
        }
    });


    jQuery.validator.methods["date"] = function (value, element) { return true; }
</script>
