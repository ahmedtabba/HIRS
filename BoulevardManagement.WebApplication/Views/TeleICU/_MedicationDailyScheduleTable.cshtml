        @*var datetimepicker = $("#datetimepicker").data("kendoDateTimePicker");
        datetimepicker.value("@DateTime.Now.Day" + "/" + "@DateTime.Now.Month" + "/" + "@DateTime.Now.Year" + " " + "@DateTime.Now.ToString("hh:mm tt")");*@
    });
         $('#vital-sign-content').load('@Url.Action("GetVitalSignForm", "TeleICU", new { VitalSignId = "", ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {
        @*var datetimepicker = $("#datetimepicker").data("kendoDateTimePicker");
        datetimepicker.value("@DateTime.Now.Day" + "/" + "@DateTime.Now.Month" + "/" + "@DateTime.Now.Year" + " " + "@DateTime.Now.ToString("hh:mm tt")");*@
    });
         $('#pump-content').load('@Url.Action("GetPumpForm", "TeleICU", new { PumpId = "", ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {
        @*var datetimepicker = $("#datetimepicker").data("kendoDateTimePicker");
        datetimepicker.value("@DateTime.Now.Day" + "/" + "@DateTime.Now.Month" + "/" + "@DateTime.Now.Year" + " " + "@DateTime.Now.ToString("hh:mm tt")");*@
    });









    $("input[type=number]").on("keypress", function (evt) {

        if (evt.which != 8 && evt.which != 0 && evt.which < 48 || evt.which > 57) {
            evt.preventDefault();
        }
    });
</script>
