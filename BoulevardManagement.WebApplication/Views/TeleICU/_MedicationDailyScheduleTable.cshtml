<script>
       $(document).ready(function () {

        if ('@viewMode'=='True') {
            $('#TelICUMedicationDailyScheduleFormId input').attr('readonly', 'readonly');
            $('#TelICUMedicationDailyScheduleFormId textarea').attr('readonly', 'readonly');

        }
    });
    $("#TelICUMedicationDailyScheduleFormId").on("submit", function (e) {

            e.preventDefault();
        var formData = new FormData();


        var formdataSerialize = $(this).serializeArray();
        for (var i = 0; i < formdataSerialize.length; i++) {

            formData.append(formdataSerialize[i].name, formdataSerialize[i].value);
        }


       // console.log(formdata11);
            $.ajax({
                url: "@(Url.Action("UpdateMedicationDailySchedule", "TeleICU"))",
                type: "POST",
                data: formData,
                contentType: false,
                processData: false,
                success: function (data) {
                    if (data.Success) {
                        ShowSuccessfllyMsg(data.Message);
                        $('#main-content').load('@Url.Action("GetTelICUMedicationScheduleTable", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {});
                        $('#sticky-menu').load('@Url.Action("GetSickyMenu", "TeleICU", new { ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {
                            onmenueload();
                            $("#MedicationDailyScheduleTableBtn").addClass("active");
                        });
                    } else {
                        onJSError(data.Message);
                        $("#saveMedicationDialy").removeAttr("disabled");
                    }
                }
            });




           // $("#ManifestItemFormId").submit();
    });

    $("#saveMedicationDialy").on("click", function (e) {

        //  $('#voice').val(formData);
        $('#TelICUMedicationDailyScheduleFormId').validate();
        if ($("#TelICUMedicationDailyScheduleFormId").valid()) {
            $("#saveMedicationDialy").attr("disabled", "disabled");



            $("#TelICUMedicationDailyScheduleFormId").submit();
        }
    });
    $('#midecation-scheduler-content').load('@Url.Action("GetMedicationSchedulerForm", "TeleICU", new { MedicationSchedulerId = "", ICUId = HashIdsManager.Encrypt(Model.TeleICUId) })', function () {
        @*var datetimepicker = $("#datetimepicker").data("kendoDateTimePicker");
        datetimepicker.value("@DateTime.Now.Day" + "/" + "@DateTime.Now.Month" + "/" + "@DateTime.Now.Year" + " " + "@DateTime.Now.ToString("hh:mm tt")");*@
    });
