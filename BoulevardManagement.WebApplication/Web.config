    <add name="defaultconnection" connectionString="data source=LAPTOP-6JQKBDEL\SQLEXPRESS;initial catalog=multiLangTemplateBoulevardUsers;User Id=sa;Password=1;multipleactiveresultsets=true" providerName="system.data.sqlclient" />
    <add name="boulevardmanagementcontext" connectionString="data source=LAPTOP-6JQKBDEL\SQLEXPRESS;initial catalog=multiLangTemplateBoulevardManagement;User Id=sa;Password=1;multipleactiveresultsets=true" providerName="system.data.sqlclient" />
