  <appSettings>
    <add key="webpages:Version" value="3.0.0.0" />
    <add key="webpages:Enabled" value="false" />
    <add key="ClientValidationEnabled" value="true" />
    <add key="UnobtrusiveJavaScriptEnabled" value="true" />
    <add key="RoundDecimalCount" value="2" />
    <add key="InsertIdentitySeedData" value="true" />
    <add key="SuperUserEmail" value="manager@boulevard.com" />
    <add key="SuperUserFullName" value="Boulevard" />
    <add key="MaxDaysToCleanErrorLog" value="30" />
    <add key="CsvFilePathURL" value="~/Files/" />
    <add key="TestMail" value="TestMail@gmail.com" />
    <add key="HtmlTemplatePath" value="~/Content/HtmlTemplates/" />
    <add key="SystemURL" value="http://localhost/Boulevard/" />
    <add key="MvcSiteMapProvider_IncludeAssembliesForScan" value="Boulevard.WebApplication" />
    <add key="MvcSiteMapProvider_UseExternalDIContainer" value="false" />
    <add key="MvcSiteMapProvider_ScanAssembliesForSiteMapNodes" value="true" />
    <add key="ProfilePathURL" value="~/Uploads/Profile/" />
    <add key="AttachmentsPathURL" value="~/Uploads/Attachment/" />
    <add key="TempAttachmentsPathURL" value="~/Uploads/Temp/" />
